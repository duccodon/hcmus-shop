<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="TableHeaderBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource TableHeaderBackground}" />
        <Setter Property="BorderBrush" Value="{StaticResource TableHeaderBorder}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="12,8" />
    </Style>

    <Style x:Key="TableRowBorderStyle" TargetType="Border">
        <Setter Property="BorderBrush" Value="{StaticResource TableRowBorder}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="12,10" />
    </Style>

</ResourceDictionary>
