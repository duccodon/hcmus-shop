<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Background" Value="{StaticResource AccentPurple}" />
        <Setter Property="Foreground" Value="White" />
    </Style>

    <Style x:Key="GhostButtonStyle" TargetType="Button">
        <Setter Property="Padding" Value="6" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style x:Key="DangerButtonStyle" TargetType="Button">
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Background" Value="{StaticResource DangerBackgroundSubtle}" />
    </Style>

    <Style x:Key="PillButtonStyle" TargetType="Button">
        <Setter Property="Padding" Value="18,8" />
        <Setter Property="CornerRadius" Value="999" />
    </Style>

    <Style
        x:Key="PrimaryPillButtonStyle"
        BasedOn="{StaticResource PillButtonStyle}"
        TargetType="Button">
        <Setter Property="Background" Value="{StaticResource LoginPrimaryBrush}" />
        <Setter Property="Foreground" Value="White" />
    </Style>

    <Style x:Key="PaginationButtonStyle" TargetType="Button">
        <Setter Property="MinWidth" Value="36" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Padding" Value="10,0" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>

    <Style
        x:Key="ImageUploadAddButtonStyle"
        BasedOn="{StaticResource GhostButtonStyle}"
        TargetType="Button">
        <Setter Property="Width" Value="72" />
        <Setter Property="Height" Value="72" />
        <Setter Property="Background" Value="{StaticResource ImageUploadButtonBackground}" />
        <Setter Property="Foreground" Value="{StaticResource LoginPrimaryBrush}" />
    </Style>

    <Style x:Key="ImageUploadPreviewButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="72" />
        <Setter Property="Height" Value="72" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="{StaticResource ImageUploadPreviewBackground}" />
        <Setter Property="BorderBrush" Value="{StaticResource TableRowBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>
</ResourceDictionary>
