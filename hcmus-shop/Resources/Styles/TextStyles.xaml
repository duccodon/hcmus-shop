<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="PageTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
    </Style>
    <Style x:Key="CardTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="26" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
    </Style>
    <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
    </Style>
    <Style x:Key="TableHeaderTextStyle" TargetType="TextBlock">
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
    </Style>
    <Style x:Key="BodyTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
    </Style>
    <Style x:Key="BodySecondaryTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
    </Style>
    <Style x:Key="CaptionSecondaryTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
    </Style>
    <Style x:Key="StatusBadgeTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
    </Style>
    <Style x:Key="EmptyStateTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
    </Style>
    <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
    </Style>
    <Style x:Key="HeaderProductIconStyle" TargetType="FontIcon">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
    </Style>
    <Style x:Key="ImagePlaceholderIconStyle" TargetType="FontIcon">
        <Setter Property="FontSize" Value="48" />
        <Setter Property="Foreground" Value="{StaticResource LoginPrimaryBrush}" />
    </Style>
    <Style x:Key="ImageAddIconStyle" TargetType="FontIcon">
        <Setter Property="FontSize" Value="18" />
    </Style>
    <Style x:Key="BodySecondarySmallTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
    </Style>
    <Style x:Key="SectionHeaderTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
    </Style>
    <Style x:Key="HeaderWelcomeTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
    </Style>
    <Style x:Key="AdminTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="28" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
    </Style>
    <Style x:Key="BrandBigIconStyle" TargetType="FontIcon">
        <Setter Property="FontSize" Value="64" />
        <Setter Property="Foreground" Value="{StaticResource LoginCardBackgroundBrush}" />
    </Style>
    <Style x:Key="SortGlyphIconStyle" TargetType="FontIcon">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
    </Style>
</ResourceDictionary>
