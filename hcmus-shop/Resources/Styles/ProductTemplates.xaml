<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="using:hcmus_shop.Views.Components">

    <DataTemplate x:Key="ProductRowTemplate">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="56" />
                <ColumnDefinition Width="2.6*" />
                <ColumnDefinition Width="1.4*" />
                <ColumnDefinition Width="1.4*" />
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="1.4*" />
                <ColumnDefinition Width="80" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource TableRowBorderStyle}">
                <CheckBox
                    Width="22"
                    Height="22"
                    IsChecked="{Binding IsSelected, Mode=TwoWay}" />
            </Border>

            <Border
                Grid.Column="1"
                BorderThickness="1,0,0,1"
                Style="{StaticResource TableRowBorderStyle}">
                <StackPanel
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="10">
                    <Border VerticalAlignment="Center" Style="{StaticResource ProductIconContainerStyle}">
                        <FontIcon
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="Segoe Fluent Icons"
                            Foreground="{StaticResource TextSecondary}"
                            Glyph="&#xEC8A;" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource BodyTextStyle}" Text="{Binding Name}" />
                        <TextBlock Style="{StaticResource CaptionSecondaryTextStyle}" Text="{Binding Sku}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border
                Grid.Column="2"
                BorderThickness="1,0,0,1"
                Style="{StaticResource TableRowBorderStyle}">
                <TextBlock
                    VerticalAlignment="Center"
                    Style="{StaticResource BodyTextStyle}"
                    Text="{Binding CategoryDisplay}" />
            </Border>

            <Border
                Grid.Column="3"
                BorderThickness="1,0,0,1"
                Style="{StaticResource TableRowBorderStyle}">
                <StackPanel
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="4">
                    <TextBlock Style="{StaticResource BodyTextStyle}" Text="{Binding StockQuantity}" />
                    <TextBlock
                        Foreground="{Binding StockTone, Converter={StaticResource StockToneForegroundConverter}}"
                        Style="{StaticResource BodySecondaryTextStyle}"
                        Text="{Binding StockLabel}" />
                </StackPanel>
            </Border>

            <Border
                Grid.Column="4"
                BorderThickness="1,0,0,1"
                Style="{StaticResource TableRowBorderStyle}">
                <TextBlock
                    VerticalAlignment="Center"
                    Style="{StaticResource BodyTextStyle}"
                    Text="{Binding PriceDisplay}" />
            </Border>

            <Border
                Grid.Column="5"
                BorderThickness="1,0,0,1"
                Style="{StaticResource TableRowBorderStyle}">
                <components:StatusBadge StatusText="{Binding StatusText}" StatusTone="{Binding StatusTone}" />
            </Border>

            <Border
                Grid.Column="6"
                BorderThickness="1,0,0,1"
                Style="{StaticResource TableRowBorderStyle}">
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="4">
                    <Button Style="{StaticResource GhostButtonStyle}" ToolTipService.ToolTip="Edit product">
                        <FontIcon
                            FontFamily="Segoe Fluent Icons"
                            Foreground="{StaticResource TextSecondary}"
                            Glyph="&#xE70F;" />
                    </Button>
                    <Button Style="{StaticResource GhostButtonStyle}" ToolTipService.ToolTip="Delete product">
                        <FontIcon
                            FontFamily="Segoe Fluent Icons"
                            Foreground="{StaticResource DangerForeground}"
                            Glyph="&#xE74D;" />
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </DataTemplate>
</ResourceDictionary>
