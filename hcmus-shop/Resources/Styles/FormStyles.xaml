<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="FormTextBoxStyle" TargetType="TextBox">
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="Background" Value="White" />
        <Setter Property="BorderBrush" Value="{StaticResource LoginInputBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
    </Style>

    <Style x:Key="FormComboBoxStyle" TargetType="ComboBox">
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="Background" Value="White" />
        <Setter Property="BorderBrush" Value="{StaticResource LoginInputBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
    </Style>

    <Style x:Key="FormNumberBoxStyle" TargetType="NumberBox">
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="Background" Value="White" />
        <Setter Property="BorderBrush" Value="{StaticResource LoginInputBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
    </Style>

    <Style x:Key="SearchTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource FormTextBoxStyle}">
        <Setter Property="Padding" Value="12,9,40,9" />
    </Style>

</ResourceDictionary>
