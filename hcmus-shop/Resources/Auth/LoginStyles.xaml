<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============ Input State Overrides ============ -->

    <!-- TextBox / PasswordBox — no visual change on hover/focus -->
    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#D1C9C2" />
    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#D1C9C2" />
    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="White" />
    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="White" />
    <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="#1F1F1F" />
    <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#1F1F1F" />

    <!-- Checkbox — brown accent, dark text in all states -->
    <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillChecked" Color="#7B4F2E" />
    <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillCheckedPointerOver" Color="#9B6F4E" />
    <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillCheckedPressed" Color="#5B3F1E" />
    <SolidColorBrush x:Key="CheckBoxForegroundUnchecked" Color="#1F1F1F" />
    <SolidColorBrush x:Key="CheckBoxForegroundUncheckedPointerOver" Color="#1F1F1F" />
    <SolidColorBrush x:Key="CheckBoxForegroundUncheckedPressed" Color="#1F1F1F" />
    <SolidColorBrush x:Key="CheckBoxForegroundChecked" Color="#1F1F1F" />
    <SolidColorBrush x:Key="CheckBoxForegroundCheckedPointerOver" Color="#1F1F1F" />
    <SolidColorBrush x:Key="CheckBoxForegroundCheckedPressed" Color="#1F1F1F" />

    <!-- AccentButton — brown theme -->
    <SolidColorBrush x:Key="AccentButtonBackgroundPointerOver" Color="#9B6F4E" />
    <SolidColorBrush x:Key="AccentButtonBackgroundPressed" Color="#5B3F1E" />
    <SolidColorBrush x:Key="AccentButtonForeground" Color="White" />
    <SolidColorBrush x:Key="AccentButtonForegroundPointerOver" Color="White" />
    <SolidColorBrush x:Key="AccentButtonForegroundPressed" Color="White" />

    <!-- ============ Component Styles ============ -->

    <Style x:Key="LoginCardBorderStyle" TargetType="Border">
        <Setter Property="BorderBrush" Value="{StaticResource LoginOutlineBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="30" />
        <Setter Property="Background" Value="{StaticResource LoginCardBackgroundBrush}" />
    </Style>

    <Style x:Key="LoginTextBoxStyle" TargetType="TextBox">
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="Background" Value="White" />
        <Setter Property="BorderBrush" Value="{StaticResource LoginInputBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
    </Style>

    <Style x:Key="LoginPasswordBoxStyle" TargetType="PasswordBox">
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="Background" Value="White" />
        <Setter Property="BorderBrush" Value="{StaticResource LoginInputBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="PasswordRevealMode" Value="Peek" />
    </Style>

    <Style x:Key="LoginPrimaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource LoginPrimaryBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="18,10" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="LoginOutlineButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="BorderBrush" Value="{StaticResource LoginInputBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="18,8" />
        <Setter Property="MinWidth" Value="90" />
    </Style>

    <Style x:Key="LoginHyperlinkButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource LoginPrimaryBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

</ResourceDictionary>
