<Page
    x:Class="hcmus_shop.Views.ProductsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="using:hcmus_shop.Views.Components"
    xmlns:local="using:hcmus_shop.Views"
    xmlns:pagination="using:hcmus_shop.Views.Components.Pagination"
    x:Name="Root">
    <Grid Background="{StaticResource DashboardBackground}">
        <ScrollViewer>
            <Grid Margin="24">
                <Border Style="{StaticResource ContentCardBorderStyle}">
                    <Grid RowSpacing="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <components:PageHeader
                            Title="Products List"
                            PrimaryActionCommand="{x:Bind ViewModel.AddProductCommand}"
                            PrimaryActionLabel="+ Add Product" />

                        <Border
                            Grid.Row="1"
                            Height="1"
                            Background="{StaticResource DividerBrush}" />

                        <components:SearchFilterBar Grid.Row="2" SearchText="{x:Bind ViewModel.SearchQuery, Mode=TwoWay}">
                            <components:SearchFilterBar.FiltersContent>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Style="{StaticResource PrimaryButtonStyle}">
                                        <Button.Flyout>
                                            <Flyout Placement="Bottom">
                                                <StackPanel Spacing="10" Style="{StaticResource FilterFlyoutContentStyle}">
                                                    <TextBlock Style="{StaticResource BodySecondaryTextStyle}" Text="From" />
                                                    <CalendarDatePicker
                                                        x:Name="DateFromPicker"
                                                        DateChanged="DateFromPicker_DateChanged"
                                                        PlaceholderText="Start date" />
                                                    <TextBlock Style="{StaticResource BodySecondaryTextStyle}" Text="To" />
                                                    <CalendarDatePicker
                                                        x:Name="DateToPicker"
                                                        DateChanged="DateToPicker_DateChanged"
                                                        PlaceholderText="End date" />
                                                </StackPanel>
                                            </Flyout>
                                        </Button.Flyout>
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon
                                                VerticalAlignment="Center"
                                                FontFamily="Segoe Fluent Icons"
                                                Glyph="&#xE787;" />
                                            <TextBlock
                                                x:Name="DateRangeLabel"
                                                VerticalAlignment="Center"
                                                Style="{StaticResource BodySecondaryTextStyle}"
                                                Text="Date Range" />
                                        </StackPanel>
                                    </Button>
                                    <ComboBox
                                        Width="160"
                                        DisplayMemberPath="Name"
                                        ItemsSource="{x:Bind ViewModel.BrandOptions, Mode=OneWay}"
                                        PlaceholderText="Brand"
                                        SelectedValue="{x:Bind ViewModel.SelectedBrandId, Mode=TwoWay}"
                                        SelectedValuePath="Id"
                                        Style="{StaticResource FormComboBoxStyle}" />
                                    <ComboBox
                                        Width="180"
                                        DisplayMemberPath="Name"
                                        ItemsSource="{x:Bind ViewModel.CategoryOptions, Mode=OneWay}"
                                        PlaceholderText="Category"
                                        SelectedValue="{x:Bind ViewModel.SelectedCategoryId, Mode=TwoWay}"
                                        SelectedValuePath="Id"
                                        Style="{StaticResource FormComboBoxStyle}" />
                                    <Button Command="{x:Bind ViewModel.ClearFiltersCommand}" Style="{StaticResource PrimaryButtonStyle}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon
                                                VerticalAlignment="Center"
                                                FontFamily="Segoe Fluent Icons"
                                                Glyph="&#xE894;" />
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                Style="{StaticResource BodySecondaryTextStyle}"
                                                Text="Clear" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </components:SearchFilterBar.FiltersContent>
                        </components:SearchFilterBar>

                        <components:BulkActionBar
                            Grid.Row="3"
                            DeleteCommand="{x:Bind ViewModel.BulkDeleteCommand}"
                            IsVisible="{x:Bind ViewModel.HasSelection, Mode=OneWay}"
                            SelectionText="{x:Bind ViewModel.SelectionActionText, Mode=OneWay}"
                            ToggleStatusCommand="{x:Bind ViewModel.BulkToggleStatusCommand}" />

                        <Grid Grid.Row="4" MinHeight="300">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <InfoBar
                                Grid.RowSpan="2"
                                Margin="0,0,0,12"
                                IsClosable="False"
                                IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                                Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                                Severity="Error" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="56" />
                                    <ColumnDefinition Width="2.6*" />
                                    <ColumnDefinition Width="1.4*" />
                                    <ColumnDefinition Width="1.4*" />
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="1.4*" />
                                    <ColumnDefinition Width="80" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource TableHeaderBorderStyle}">
                                    <CheckBox
                                        x:Name="SelectAllCheckBox"
                                        Width="22"
                                        Height="22"
                                        IsChecked="{x:Bind ViewModel.IsAllOnPageSelected, Mode=TwoWay}" />
                                </Border>
                                <Border
                                    Grid.Column="1"
                                    BorderThickness="1,0,0,1"
                                    Style="{StaticResource TableHeaderBorderStyle}">
                                    <TextBlock Style="{StaticResource TableHeaderTextStyle}" Text="Product Name" />
                                </Border>
                                <Border
                                    Grid.Column="2"
                                    BorderThickness="1,0,0,1"
                                    Style="{StaticResource TableHeaderBorderStyle}">
                                    <TextBlock Style="{StaticResource TableHeaderTextStyle}" Text="Category" />
                                </Border>
                                <Border
                                    Grid.Column="3"
                                    BorderThickness="1,0,0,1"
                                    Style="{StaticResource TableHeaderBorderStyle}">
                                    <TextBlock Style="{StaticResource TableHeaderTextStyle}" Text="Stock" />
                                </Border>
                                <Border
                                    Grid.Column="4"
                                    BorderThickness="1,0,0,1"
                                    Style="{StaticResource TableHeaderBorderStyle}">
                                    <TextBlock Style="{StaticResource TableHeaderTextStyle}" Text="Price" />
                                </Border>
                                <Border
                                    Grid.Column="5"
                                    BorderThickness="1,0,0,1"
                                    Style="{StaticResource TableHeaderBorderStyle}">
                                    <TextBlock Style="{StaticResource TableHeaderTextStyle}" Text="Status" />
                                </Border>
                                <Border
                                    Grid.Column="6"
                                    BorderThickness="1,0,0,1"
                                    Style="{StaticResource TableHeaderBorderStyle}">
                                    <TextBlock Style="{StaticResource TableHeaderTextStyle}" Text="Action" />
                                </Border>
                            </Grid>

                            <ScrollViewer
                                Grid.Row="1"
                                HorizontalScrollBarVisibility="Disabled"
                                VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemTemplate="{StaticResource ProductRowTemplate}" ItemsSource="{x:Bind ViewModel.PagedProducts, Mode=OneWay}" />
                            </ScrollViewer>

                            <Border
                                Grid.RowSpan="2"
                                Background="{StaticResource CardBackground}"
                                Opacity="0.85"
                                Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <ProgressRing
                                    Width="36"
                                    Height="36"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    IsActive="True" />
                            </Border>

                            <Border
                                Grid.Row="1"
                                Background="Transparent"
                                Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource EmptyStateTextStyle}"
                                    Text="No products found." />
                            </Border>
                        </Grid>

                        <pagination:PaginationFooter
                            Grid.Row="5"
                            PageButtonClickCommand="{x:Bind ViewModel.GoToPageCommand}"
                            PageButtons="{x:Bind ViewModel.PageButtons, Mode=OneWay}"
                            PageSizeOptions="{x:Bind ViewModel.PageSizeOptions, Mode=OneWay}"
                            ResultText="{x:Bind ViewModel.ResultText, Mode=OneWay}"
                            SelectedPageSize="{x:Bind ViewModel.SelectedPageSize, Mode=TwoWay}" />
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>

