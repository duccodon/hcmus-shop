<Page
    x:Class="hcmus_shop.Views.ProductsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:hcmus_shop.Views"
    xmlns:components="using:hcmus_shop.Views.Components.Pagination"
    xmlns:vm="using:hcmus_shop.ViewModels.Products"
    x:Name="Root">

    <Grid Background="{StaticResource DashboardBackground}">
        <ScrollViewer>
            <Grid Margin="24">
                <Border
                    Background="{StaticResource CardBackground}"
                    CornerRadius="16"
                    Padding="20">
                    <Grid RowSpacing="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- ── Row 0: Title + Action Buttons ── -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                VerticalAlignment="Center"
                                Text="Products List"
                                FontSize="22"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimary}" />

                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                <Button Content="Import" Padding="16,8" CornerRadius="8" />
                                <Button Content="Export" Padding="16,8" CornerRadius="8" />
                                <Button
                                    Content="+ Add Product"
                                    Padding="16,8"
                                    CornerRadius="8"
                                    Command="{x:Bind ViewModel.AddProductCommand}"
                                    Background="{StaticResource AccentPurple}"
                                    Foreground="White" />
                            </StackPanel>
                        </Grid>

                        <!-- ── Row 1: Divider ── -->
                        <Border Grid.Row="1" Height="1" Background="{StaticResource DividerBrush}" />

                        <!-- ── Row 2: Search + Date range + Filter buttons ── -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MaxWidth="320" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Search -->
                            <Grid VerticalAlignment="Center">
                                <TextBox
                                    x:Name="SearchBox"
                                    PlaceholderText="Search"
                                    Padding="12,9,40,9"
                                    CornerRadius="8"
                                    Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <FontIcon
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Margin="0,0,12,0"
                                    FontFamily="Segoe Fluent Icons"
                                    Glyph="&#xE721;"
                                    FontSize="14"
                                    Foreground="{StaticResource TextSecondary}" />
                            </Grid>

                            <!-- Filter buttons -->
                            <StackPanel
                                Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="8"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">

                                <!-- Date range flyout -->
                                <Button Padding="12,8" CornerRadius="8">
                                    <Button.Flyout>
                                        <Flyout Placement="Bottom">
                                            <StackPanel Spacing="10" Padding="4">
                                                <TextBlock Text="From" FontSize="12" Foreground="{StaticResource TextSecondary}" />
                                                <CalendarDatePicker
                                                    x:Name="DateFromPicker"
                                                    PlaceholderText="Start date"
                                                    DateChanged="DateFromPicker_DateChanged" />
                                                <TextBlock Text="To" FontSize="12" Foreground="{StaticResource TextSecondary}" />
                                                <CalendarDatePicker
                                                    x:Name="DateToPicker"
                                                    PlaceholderText="End date"
                                                    DateChanged="DateToPicker_DateChanged" />
                                            </StackPanel>
                                        </Flyout>
                                    </Button.Flyout>
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon
                                            FontFamily="Segoe Fluent Icons"
                                            Glyph="&#xE787;"
                                            FontSize="12"
                                            VerticalAlignment="Center" />
                                        <TextBlock
                                            x:Name="DateRangeLabel"
                                            Text="Date Range"
                                            FontSize="12"
                                            VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>

                                <ComboBox
                                    Width="160"
                                    PlaceholderText="Brand"
                                    ItemsSource="{x:Bind ViewModel.BrandOptions, Mode=OneWay}"
                                    DisplayMemberPath="Name"
                                    SelectedValuePath="Id"
                                    SelectedValue="{x:Bind ViewModel.SelectedBrandId, Mode=TwoWay}" />

                                <ComboBox
                                    Width="180"
                                    PlaceholderText="Category"
                                    ItemsSource="{x:Bind ViewModel.CategoryOptions, Mode=OneWay}"
                                    DisplayMemberPath="Name"
                                    SelectedValuePath="Id"
                                    SelectedValue="{x:Bind ViewModel.SelectedCategoryId, Mode=TwoWay}" />

                                <ComboBox
                                    Width="120"
                                    PlaceholderText="Sort By"
                                    ItemsSource="{x:Bind ViewModel.SortFieldOptions, Mode=OneWay}"
                                    DisplayMemberPath="Name"
                                    SelectedValuePath="Value"
                                    SelectedValue="{x:Bind ViewModel.SelectedSortField, Mode=TwoWay}" />

                                <ComboBox
                                    Width="95"
                                    PlaceholderText="Order"
                                    ItemsSource="{x:Bind ViewModel.SortOrderOptions, Mode=OneWay}"
                                    DisplayMemberPath="Name"
                                    SelectedValuePath="Value"
                                    SelectedValue="{x:Bind ViewModel.SelectedSortOrder, Mode=TwoWay}" />

                                <Button
                                    Padding="12,8"
                                    CornerRadius="8"
                                    Command="{x:Bind ViewModel.ClearFiltersCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon
                                            FontFamily="Segoe Fluent Icons"
                                            Glyph="&#xE894;"
                                            FontSize="12"
                                            VerticalAlignment="Center" />
                                        <TextBlock Text="Clear" FontSize="12" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <!-- ── Row 3: Bulk-action bar (visible only when items selected) ── -->
                        <Grid
                            Grid.Row="3"
                            Visibility="{x:Bind ViewModel.HasSelection, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Border
                                Background="{StaticResource SelectionHighlight}"
                                CornerRadius="8"
                                Padding="12,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock
                                        VerticalAlignment="Center"
                                        Text="{x:Bind ViewModel.SelectionActionText, Mode=OneWay}"
                                        FontSize="13"
                                        Foreground="{StaticResource TextSecondary}" />

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                        <Button
                                            Command="{x:Bind ViewModel.BulkToggleStatusCommand}"
                                            Padding="10,6"
                                            CornerRadius="8"
                                            ToolTipService.ToolTip="Toggle active / inactive">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon
                                                    FontFamily="Segoe Fluent Icons"
                                                    Glyph="&#xE70F;"
                                                    FontSize="13" />
                                                <TextBlock Text="Update Status" FontSize="12" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button>

                                        <Button
                                            Command="{x:Bind ViewModel.BulkDeleteCommand}"
                                            Padding="10,6"
                                            CornerRadius="8"
                                            Background="{StaticResource DangerBackgroundSubtle}"
                                            ToolTipService.ToolTip="Delete selected">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon
                                                    FontFamily="Segoe Fluent Icons"
                                                    Glyph="&#xE74D;"
                                                    FontSize="13"
                                                    Foreground="{StaticResource DangerForeground}" />
                                                <TextBlock Text="Delete" FontSize="12" Foreground="{StaticResource DangerForeground}" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- ── Row 4: Table ── -->
                        <Grid Grid.Row="4" MinHeight="300">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <InfoBar
                                Grid.RowSpan="2"
                                Margin="0,0,0,12"
                                IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                                IsClosable="False"
                                Severity="Error"
                                Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" />

                            <!-- Table header -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="56" />
                                    <ColumnDefinition Width="2.6*" />
                                    <ColumnDefinition Width="1.4*" />
                                    <ColumnDefinition Width="1.4*" />
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="1.4*" />
                                    <ColumnDefinition Width="80" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                    Padding="12,10"
                                    Background="{StaticResource TableHeaderBackground}"
                                    BorderBrush="{StaticResource TableHeaderBorder}"
                                    BorderThickness="0,0,0,1">
                                    <CheckBox
                                        x:Name="SelectAllCheckBox"
                                        Width="22"
                                        Height="22"
                                        IsChecked="{x:Bind ViewModel.IsAllOnPageSelected, Mode=TwoWay}" />
                                </Border>

                                <Border Grid.Column="1" Padding="12,10" Background="{StaticResource TableHeaderBackground}" BorderBrush="{StaticResource TableHeaderBorder}" BorderThickness="1,0,0,1">
                                    <TextBlock Text="Product Name" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource TextSecondary}" />
                                </Border>

                                <Border Grid.Column="2" Padding="12,10" Background="{StaticResource TableHeaderBackground}" BorderBrush="{StaticResource TableHeaderBorder}" BorderThickness="1,0,0,1">
                                    <TextBlock Text="Category" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource TextSecondary}" />
                                </Border>

                                <Border Grid.Column="3" Padding="12,10" Background="{StaticResource TableHeaderBackground}" BorderBrush="{StaticResource TableHeaderBorder}" BorderThickness="1,0,0,1">
                                    <TextBlock Text="Stock" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource TextSecondary}" />
                                </Border>

                                <Border Grid.Column="4" Padding="12,10" Background="{StaticResource TableHeaderBackground}" BorderBrush="{StaticResource TableHeaderBorder}" BorderThickness="1,0,0,1">
                                    <TextBlock Text="Price" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource TextSecondary}" />
                                </Border>

                                <Border Grid.Column="5" Padding="12,10" Background="{StaticResource TableHeaderBackground}" BorderBrush="{StaticResource TableHeaderBorder}" BorderThickness="1,0,0,1">
                                    <TextBlock Text="Status" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource TextSecondary}" />
                                </Border>

                                <Border Grid.Column="6" Padding="12,10" Background="{StaticResource TableHeaderBackground}" BorderBrush="{StaticResource TableHeaderBorder}" BorderThickness="1,0,0,1">
                                    <TextBlock Text="Action" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource TextSecondary}" />
                                </Border>
                            </Grid>

                            <!-- Table rows -->
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{x:Bind ViewModel.PagedProducts, Mode=OneWay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ProductRowViewModel">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="56" />
                                                    <ColumnDefinition Width="2.6*" />
                                                    <ColumnDefinition Width="1.4*" />
                                                    <ColumnDefinition Width="1.4*" />
                                                    <ColumnDefinition Width="1*" />
                                                    <ColumnDefinition Width="1.4*" />
                                                    <ColumnDefinition Width="80" />
                                                </Grid.ColumnDefinitions>

                                                <!-- Checkbox column in row -->
                                                <Border Grid.Column="0"
                                                        Padding="12,12"
                                                        BorderBrush="{StaticResource TableRowBorder}"
                                                        BorderThickness="0,0,0,1">
                                                    <CheckBox
                                                        Width="22"
                                                        Height="22"
                                                        IsChecked="{x:Bind IsSelected, Mode=TwoWay}" />
                                                </Border>

                                                <!-- Product name + SKU -->
                                                <Border Grid.Column="1" Padding="12,12" BorderBrush="{StaticResource TableRowBorder}" BorderThickness="1,0,0,1">
                                                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                                        <Border
                                                            Width="32" Height="32"
                                                            CornerRadius="8"
                                                            Background="#12000000"
                                                            VerticalAlignment="Center">
                                                            <Grid>
                                                                <Image
                                                                    Stretch="UniformToFill"
                                                                    Visibility="{x:Bind HasThumbnail, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                    <Image.Source>
                                                                        <BitmapImage UriSource="{x:Bind ThumbnailUri, Mode=OneWay}" />
                                                                    </Image.Source>
                                                                </Image>
                                                                <FontIcon
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"
                                                                    FontFamily="Segoe Fluent Icons"
                                                                    Glyph="{x:Bind FallbackGlyph, Mode=OneWay}"
                                                                    FontSize="14"
                                                                    Foreground="{StaticResource TextSecondary}"
                                                                    Visibility="{x:Bind HasThumbnail, Mode=OneWay, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                                            </Grid>
                                                        </Border>
                                                        <StackPanel VerticalAlignment="Center">
                                                            <TextBlock Text="{x:Bind Name, Mode=OneWay}" FontSize="13" Foreground="{StaticResource TextPrimary}" />
                                                            <TextBlock Text="{x:Bind Sku, Mode=OneWay}" FontSize="11" Foreground="{StaticResource TextSecondary}" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Category -->
                                                <Border Grid.Column="2" Padding="12,12" BorderBrush="{StaticResource TableRowBorder}" BorderThickness="1,0,0,1">
                                                    <TextBlock VerticalAlignment="Center" Text="{x:Bind CategoryDisplay, Mode=OneWay}" FontSize="13" Foreground="{StaticResource TextPrimary}" />
                                                </Border>

                                                <!-- Stock -->
                                                <Border Grid.Column="3" Padding="12,12" BorderBrush="{StaticResource TableRowBorder}" BorderThickness="1,0,0,1">
                                                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                                        <TextBlock Text="{x:Bind StockQuantity, Mode=OneWay}" FontSize="13" Foreground="{StaticResource TextPrimary}" />
                                                        <TextBlock Text="{x:Bind StockLabel, Mode=OneWay}" FontSize="12" Foreground="{x:Bind StockTone, Mode=OneWay, Converter={StaticResource StockToneForegroundConverter}}" />
                                                    </StackPanel>
                                                </Border>

                                                <!-- Price -->
                                                <Border Grid.Column="4" Padding="12,12" BorderBrush="{StaticResource TableRowBorder}" BorderThickness="1,0,0,1">
                                                    <TextBlock VerticalAlignment="Center" Text="{x:Bind PriceDisplay, Mode=OneWay}" FontSize="13" Foreground="{StaticResource TextPrimary}" />
                                                </Border>

                                                <!-- Status badge -->
                                                <Border Grid.Column="5" Padding="12,8" BorderBrush="{StaticResource TableRowBorder}" BorderThickness="1,0,0,1">
                                                    <Border
                                                        Padding="10,5"
                                                        CornerRadius="99"
                                                        Background="{x:Bind StatusTone, Mode=OneWay, Converter={StaticResource StatusToneBackgroundConverter}}"
                                                        HorizontalAlignment="Left">
                                                        <TextBlock
                                                            VerticalAlignment="Center"
                                                            Text="{x:Bind StatusText, Mode=OneWay}"
                                                            FontSize="12"
                                                            FontWeight="SemiBold"
                                                            Foreground="{x:Bind StatusTone, Mode=OneWay, Converter={StaticResource StatusToneForegroundConverter}}" />
                                                    </Border>
                                                </Border>

                                                <!-- Action: pen + trash per row -->
                                                <Border Grid.Column="6" Padding="8,8" BorderBrush="{StaticResource TableRowBorder}" BorderThickness="1,0,0,1">
                                                    <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <Button
                                                            Padding="6"
                                                            CornerRadius="6"
                                                            Background="Transparent"
                                                            Command="{Binding DataContext.EditProductCommand, ElementName=Root}"
                                                            CommandParameter="{x:Bind ProductId}"
                                                            ToolTipService.ToolTip="Edit product">
                                                            <FontIcon
                                                                FontFamily="Segoe Fluent Icons"
                                                                Glyph="&#xE70F;"
                                                                FontSize="13"
                                                                Foreground="{StaticResource TextSecondary}" />
                                                        </Button>
                                                        <Button
                                                            Padding="6"
                                                            CornerRadius="6"
                                                            Background="Transparent"
                                                            Command="{Binding DataContext.DeleteProductCommand, ElementName=Root}"
                                                            CommandParameter="{x:Bind ProductId}"
                                                            ToolTipService.ToolTip="Delete product">
                                                            <FontIcon
                                                                FontFamily="Segoe Fluent Icons"
                                                                Glyph="&#xE74D;"
                                                                FontSize="13"
                                                                Foreground="{StaticResource DangerForeground}" />
                                                        </Button>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <Border
                                Grid.RowSpan="2"
                                Background="#66FFFFFF"
                                Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <ProgressRing
                                    IsActive="True"
                                    Width="36"
                                    Height="36"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                            </Border>

                            <Border
                                Grid.Row="1"
                                Background="Transparent"
                                Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource TextSecondary}"
                                    FontSize="14"
                                    Text="No products found." />
                            </Border>
                        </Grid>

                        <!-- ── Row 5: Footer ── -->
                        <components:PaginationFooter
                            Grid.Row="5"
                            ResultText="{x:Bind ViewModel.ResultText, Mode=OneWay}"
                            PageSizeOptions="{x:Bind ViewModel.PageSizeOptions, Mode=OneWay}"
                            SelectedPageSize="{x:Bind ViewModel.SelectedPageSize, Mode=TwoWay}"
                            PageButtons="{x:Bind ViewModel.PageButtons, Mode=OneWay}"
                            PageButtonClickCommand="{x:Bind ViewModel.GoToPageCommand}" />

                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
