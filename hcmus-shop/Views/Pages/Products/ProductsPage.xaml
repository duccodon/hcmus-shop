<Page
    x:Class="hcmus_shop.Views.ProductsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="using:hcmus_shop.Views.Components"
    xmlns:pagination="using:hcmus_shop.Views.Components.Pagination"
    xmlns:vm="using:hcmus_shop.ViewModels.Products"
    x:Name="Root">

    <Grid Background="{StaticResource DashboardBackground}">
        <ScrollViewer>
            <Grid Margin="24">
                <Border Style="{StaticResource ContentCardBorderStyle}">
                    <Grid RowSpacing="14">

                        <!--  ROWS  -->
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!--  HEADER  -->
                        <components:PageHeader
                            Title="Products List"
                            PrimaryActionCommand="{x:Bind ViewModel.AddProductCommand}"
                            PrimaryActionLabel="+ Add Product" />

                        <!--  DIVIDER  -->
                        <Border
                            Grid.Row="1"
                            Height="1"
                            Background="{StaticResource DividerBrush}" />

                        <!--  SEARCH + FILTER  -->
                        <components:SearchFilterBar Grid.Row="2" SearchText="{x:Bind ViewModel.SearchQuery, Mode=TwoWay}">

                            <components:SearchFilterBar.FiltersContent>
                                <StackPanel Orientation="Horizontal" Spacing="8">

                                    <!--  DATE  -->
                                    <Button Style="{StaticResource PrimaryButtonStyle}">
                                        <Button.Flyout>
                                            <Flyout>
                                                <StackPanel Spacing="10" Style="{StaticResource FilterFlyoutContentStyle}">
                                                    <TextBlock Style="{StaticResource BodySecondaryTextStyle}" Text="From" />
                                                    <CalendarDatePicker
                                                        x:Name="DateFromPicker"
                                                        DateChanged="DateFromPicker_DateChanged"
                                                        PlaceholderText="Start date" />
                                                    <TextBlock Style="{StaticResource BodySecondaryTextStyle}" Text="To" />
                                                    <CalendarDatePicker
                                                        x:Name="DateToPicker"
                                                        DateChanged="DateToPicker_DateChanged"
                                                        PlaceholderText="End date" />
                                                </StackPanel>
                                            </Flyout>
                                        </Button.Flyout>
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE787;" />
                                            <TextBlock
                                                x:Name="DateRangeLabel"
                                                Style="{StaticResource BodySecondaryTextStyle}"
                                                Text="Date Range" />
                                        </StackPanel>
                                    </Button>

                                    <!--  BRAND  -->
                                    <ComboBox
                                        Width="160"
                                        DisplayMemberPath="Name"
                                        ItemsSource="{x:Bind ViewModel.BrandOptions}"
                                        PlaceholderText="Brand"
                                        SelectedValue="{x:Bind ViewModel.SelectedBrandId, Mode=TwoWay}"
                                        SelectedValuePath="Id"
                                        Style="{StaticResource FormComboBoxStyle}" />

                                    <!--  CATEGORY  -->
                                    <ComboBox
                                        Width="180"
                                        DisplayMemberPath="Name"
                                        ItemsSource="{x:Bind ViewModel.CategoryOptions}"
                                        PlaceholderText="Category"
                                        SelectedValue="{x:Bind ViewModel.SelectedCategoryId, Mode=TwoWay}"
                                        SelectedValuePath="Id"
                                        Style="{StaticResource FormComboBoxStyle}" />

                                    <!--  CLEAR  -->
                                    <Button Command="{x:Bind ViewModel.ClearFiltersCommand}" Style="{StaticResource PrimaryButtonStyle}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE894;" />
                                            <TextBlock Style="{StaticResource BodySecondaryTextStyle}" Text="Clear" />
                                        </StackPanel>
                                    </Button>

                                </StackPanel>
                            </components:SearchFilterBar.FiltersContent>
                        </components:SearchFilterBar>

                        <!--  BULK ACTION  -->
                        <components:BulkActionBar
                            Grid.Row="3"
                            DeleteCommand="{x:Bind ViewModel.BulkDeleteCommand}"
                            SelectionText="{x:Bind ViewModel.SelectionActionText}"
                            ToggleStatusCommand="{x:Bind ViewModel.BulkToggleStatusCommand}"
                            Visibility="{x:Bind ViewModel.HasSelection, Converter={StaticResource BooleanToVisibilityConverter}}" />

                        <!--  TABLE  -->
                        <Grid Grid.Row="4" MinHeight="300">

                            <!--  ERROR  -->
                            <InfoBar
                                IsClosable="False"
                                IsOpen="{x:Bind ViewModel.HasError}"
                                Message="{x:Bind ViewModel.ErrorMessage}"
                                Severity="Error" />

                            <!--  LIST  -->
                            <ScrollViewer>
                                <ItemsControl ItemsSource="{x:Bind ViewModel.PagedProducts}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ProductRowViewModel">

                                            <Grid Padding="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2.5*" />
                                                    <ColumnDefinition Width="1*" />
                                                    <ColumnDefinition Width="1*" />
                                                    <ColumnDefinition Width="1*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <!--  NAME  -->
                                                <TextBlock Text="{x:Bind Name}" />

                                                <!--  STOCK  -->
                                                <TextBlock Grid.Column="1" Text="{x:Bind StockQuantity}" />

                                                <!--  PRICE  -->
                                                <TextBlock Grid.Column="2" Text="{x:Bind PriceDisplay}" />

                                                <!--  STATUS  -->
                                                <TextBlock Grid.Column="3" Text="{x:Bind StatusText}" />

                                                <!--  ACTION  -->
                                                <StackPanel Grid.Column="4" Orientation="Horizontal">
                                                    <Button
                                                        Command="{Binding DataContext.EditProductCommand, ElementName=Root}"
                                                        CommandParameter="{x:Bind ProductId}"
                                                        Style="{StaticResource GhostButtonStyle}">
                                                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE70F;" />
                                                    </Button>

                                                    <Button
                                                        Command="{Binding DataContext.DeleteProductCommand, ElementName=Root}"
                                                        CommandParameter="{x:Bind ProductId}"
                                                        Style="{StaticResource GhostButtonStyle}">
                                                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE74D;" />
                                                    </Button>
                                                </StackPanel>

                                            </Grid>

                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <!--  LOADING  -->
                            <ProgressRing
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                IsActive="{x:Bind ViewModel.IsBusy}" />

                        </Grid>

                        <!--  PAGINATION  -->
                        <pagination:PaginationFooter
                            Grid.Row="5"
                            PageButtonClickCommand="{x:Bind ViewModel.GoToPageCommand}"
                            PageButtons="{x:Bind ViewModel.PageButtons}"
                            PageSizeOptions="{x:Bind ViewModel.PageSizeOptions}"
                            ResultText="{x:Bind ViewModel.ResultText}"
                            SelectedPageSize="{x:Bind ViewModel.SelectedPageSize, Mode=TwoWay}" />

                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
