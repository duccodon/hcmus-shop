<Page
    x:Class="hcmus_shop.Views.ProductsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:hcmus_shop.Views"
    xmlns:models="using:hcmus_shop.Models"
    x:Name="Root">

    <Grid Background="{StaticResource DashboardBackground}">
        <ScrollViewer>
            <Grid Margin="24">
                <Border
                    Background="{StaticResource CardBackground}"
                    CornerRadius="16"
                    Padding="20">
                    <Grid RowSpacing="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- ── Row 0: Title + Action Buttons ── -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                VerticalAlignment="Center"
                                Text="Products List"
                                FontSize="22"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimary}" />

                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                <Button Content="Import" Padding="16,8" CornerRadius="8" />
                                <Button Content="Export" Padding="16,8" CornerRadius="8" />
                                <Button
                                    Content="+ Add Product"
                                    Padding="16,8"
                                    CornerRadius="8"
                                    Background="{StaticResource AccentPurple}"
                                    Foreground="White" />
                            </StackPanel>
                        </Grid>

                        <!-- ── Row 1: Divider ── -->
                        <Border Grid.Row="1" Height="1" Background="#14000000" />

                        <!-- ── Row 2: Search + Date range + Filter buttons ── -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MaxWidth="320" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Search -->
                            <Grid VerticalAlignment="Center">
                                <TextBox
                                    x:Name="SearchBox"
                                    PlaceholderText="Search"
                                    Padding="12,9,40,9"
                                    CornerRadius="8"
                                    TextChanged="SearchBox_TextChanged" />
                                <FontIcon
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Margin="0,0,12,0"
                                    FontFamily="Segoe Fluent Icons"
                                    Glyph="&#xE721;"
                                    FontSize="14"
                                    Foreground="{StaticResource TextSecondary}" />
                            </Grid>

                            <!-- Filter buttons -->
                            <StackPanel
                                Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="8"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">

                                <!-- Date range flyout -->
                                <Button Padding="12,8" CornerRadius="8">
                                    <Button.Flyout>
                                        <Flyout Placement="Bottom">
                                            <StackPanel Spacing="10" Padding="4">
                                                <TextBlock Text="From" FontSize="12" Foreground="{StaticResource TextSecondary}" />
                                                <CalendarDatePicker
                                                    x:Name="DateFromPicker"
                                                    PlaceholderText="Start date"
                                                    DateChanged="DateFromPicker_DateChanged" />
                                                <TextBlock Text="To" FontSize="12" Foreground="{StaticResource TextSecondary}" />
                                                <CalendarDatePicker
                                                    x:Name="DateToPicker"
                                                    PlaceholderText="End date"
                                                    DateChanged="DateToPicker_DateChanged" />
                                            </StackPanel>
                                        </Flyout>
                                    </Button.Flyout>
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon
                                            FontFamily="Segoe Fluent Icons"
                                            Glyph="&#xE787;"
                                            FontSize="12"
                                            VerticalAlignment="Center" />
                                        <TextBlock
                                            x:Name="DateRangeLabel"
                                            Text="Date Range"
                                            FontSize="12"
                                            VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>

                                <Button Content="Status" Padding="12,8" CornerRadius="8" />
                                <Button Content="Category" Padding="12,8" CornerRadius="8" />

                                <Button Padding="12,8" CornerRadius="8">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon
                                            FontFamily="Segoe Fluent Icons"
                                            Glyph="&#xE71C;"
                                            FontSize="12"
                                            VerticalAlignment="Center" />
                                        <TextBlock Text="Filter" FontSize="12" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <!-- ── Row 3: Bulk-action bar (visible only when items selected) ── -->
                        <Grid
                            Grid.Row="3"
                            Visibility="{x:Bind HasSelection, Mode=OneWay}">
                            <Border
                                Background="#0A6F7EFF"
                                CornerRadius="8"
                                Padding="12,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock
                                        VerticalAlignment="Center"
                                        Text="{x:Bind SelectionActionText, Mode=OneWay}"
                                        FontSize="13"
                                        Foreground="{StaticResource TextSecondary}" />

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                        <!-- Toggle active/inactive -->
                                        <Button
                                            Click="BulkToggleStatusButton_Click"
                                            Padding="10,6"
                                            CornerRadius="8"
                                            ToolTipService.ToolTip="Toggle active / inactive">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon
                                                    FontFamily="Segoe Fluent Icons"
                                                    Glyph="&#xE70F;"
                                                    FontSize="13" />
                                                <TextBlock Text="Update Status" FontSize="12" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button>

                                        <!-- Delete -->
                                        <Button
                                            Click="BulkDeleteButton_Click"
                                            Padding="10,6"
                                            CornerRadius="8"
                                            Background="#15DC2626"
                                            ToolTipService.ToolTip="Delete selected">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon
                                                    FontFamily="Segoe Fluent Icons"
                                                    Glyph="&#xE74D;"
                                                    FontSize="13"
                                                    Foreground="#DC2626" />
                                                <TextBlock Text="Delete" FontSize="12" Foreground="#DC2626" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- ── Row 4: Table ── -->
                        <Grid Grid.Row="4" MinHeight="300">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!-- Table header -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="56" />
                                    <ColumnDefinition Width="2.6*" />
                                    <ColumnDefinition Width="1.4*" />
                                    <ColumnDefinition Width="1.4*" />
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="1.4*" />
                                    <ColumnDefinition Width="80" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" 
                                    Padding="12,10" 
                                    Background="#0D000000" 
                                    BorderBrush="#24000000" 
                                    BorderThickness="0,0,0,1">
                                    <CheckBox
                                        x:Name="SelectAllCheckBox"
                                        Width="22"
                                        Height="22"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Click="SelectAllCheckBox_Click" />
                                </Border>

                                <Border Grid.Column="1" Padding="12,10" Background="#0D000000" BorderBrush="#24000000" BorderThickness="1,0,0,1">
                                    <TextBlock Text="Product Name" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource TextSecondary}" />
                                </Border>

                                <Border Grid.Column="2" Padding="12,10" Background="#0D000000" BorderBrush="#24000000" BorderThickness="1,0,0,1">
                                    <TextBlock Text="Category" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource TextSecondary}" />
                                </Border>

                                <Border Grid.Column="3" Padding="12,10" Background="#0D000000" BorderBrush="#24000000" BorderThickness="1,0,0,1">
                                    <TextBlock Text="Stock" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource TextSecondary}" />
                                </Border>

                                <Border Grid.Column="4" Padding="12,10" Background="#0D000000" BorderBrush="#24000000" BorderThickness="1,0,0,1">
                                    <TextBlock Text="Price" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource TextSecondary}" />
                                </Border>

                                <Border Grid.Column="5" Padding="12,10" Background="#0D000000" BorderBrush="#24000000" BorderThickness="1,0,0,1">
                                    <TextBlock Text="Status" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource TextSecondary}" />
                                </Border>

                                <Border Grid.Column="6" Padding="12,10" Background="#0D000000" BorderBrush="#24000000" BorderThickness="1,0,0,1">
                                    <TextBlock Text="Action" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource TextSecondary}" />
                                </Border>
                            </Grid>

                            <!-- Table rows -->
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{x:Bind PagedProducts, Mode=OneWay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:Product">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="56" />
                                                    <ColumnDefinition Width="2.6*" />
                                                    <ColumnDefinition Width="1.4*" />
                                                    <ColumnDefinition Width="1.4*" />
                                                    <ColumnDefinition Width="1*" />
                                                    <ColumnDefinition Width="1.4*" />
                                                    <ColumnDefinition Width="80" />
                                                </Grid.ColumnDefinitions>

                                                <!-- Checkbox column in row -->
                                                <Border Grid.Column="0"
                                                        Padding="12,12"
                                                        BorderBrush="#22000000"
                                                        BorderThickness="0,0,0,1">
                                                    <CheckBox
                                                        Width="10"
                                                        Height="10"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Tag="{x:Bind ProductId, Mode=OneWay}"
                                                        Loaded="RowCheckBox_Loaded"
                                                        Checked="RowCheckBox_Checked"
                                                        Unchecked="RowCheckBox_Unchecked" />
                                                    <!--<CheckBox x:Name="MyCheckBox" 
                                                              Content="I agree to the terms" 
                                                              Checked="RowCheckBox_Checked" 
                                                              Unchecked="RowCheckBox_Unchecked" />-->
                                                </Border>

                                                <!-- Product name + SKU -->
                                                <Border Grid.Column="1" Padding="12,12" BorderBrush="#22000000" BorderThickness="1,0,0,1">
                                                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                                        <Border
                                                            Width="32" Height="32"
                                                            CornerRadius="8"
                                                            Background="#12000000"
                                                            VerticalAlignment="Center">
                                                            <FontIcon
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                FontFamily="Segoe Fluent Icons"
                                                                Glyph="&#xEC8A;"
                                                                FontSize="14"
                                                                Foreground="{StaticResource TextSecondary}" />
                                                        </Border>
                                                        <StackPanel VerticalAlignment="Center">
                                                            <TextBlock Text="{x:Bind Name, Mode=OneWay}" FontSize="13" Foreground="{StaticResource TextPrimary}" />
                                                            <TextBlock Text="{x:Bind Sku, Mode=OneWay}" FontSize="11" Foreground="{StaticResource TextSecondary}" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Category -->
                                                <Border Grid.Column="2" Padding="12,12" BorderBrush="#22000000" BorderThickness="1,0,0,1">
                                                    <TextBlock VerticalAlignment="Center" Text="{x:Bind local:ProductsPage.GetCategoryName(Categories), Mode=OneWay}" FontSize="13" Foreground="{StaticResource TextPrimary}" />
                                                </Border>

                                                <!-- Stock -->
                                                <Border Grid.Column="3" Padding="12,12" BorderBrush="#22000000" BorderThickness="1,0,0,1">
                                                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                                        <TextBlock Text="{x:Bind StockQuantity, Mode=OneWay}" FontSize="13" Foreground="{StaticResource TextPrimary}" />
                                                        <TextBlock Text="{x:Bind local:ProductsPage.GetStockLabel(StockQuantity), Mode=OneWay}" FontSize="12" Foreground="{x:Bind local:ProductsPage.GetStockLabelBrush(StockQuantity), Mode=OneWay}" />
                                                    </StackPanel>
                                                </Border>

                                                <!-- Price -->
                                                <Border Grid.Column="4" Padding="12,12" BorderBrush="#22000000" BorderThickness="1,0,0,1">
                                                    <TextBlock VerticalAlignment="Center" Text="{x:Bind local:ProductsPage.GetSellingPriceText(SellingPrice), Mode=OneWay}" FontSize="13" Foreground="{StaticResource TextPrimary}" />
                                                </Border>

                                                <!-- Status badge -->
                                                <Border Grid.Column="5" Padding="12,8" BorderBrush="#22000000" BorderThickness="1,0,0,1">
                                                    <Border
                                                        Padding="10,5"
                                                        CornerRadius="99"
                                                        Background="{x:Bind local:ProductsPage.GetStatusBackground(IsActive, StockQuantity), Mode=OneWay}"
                                                        HorizontalAlignment="Left">
                                                        <TextBlock
                                                            VerticalAlignment="Center"
                                                            Text="{x:Bind local:ProductsPage.GetStatusText(IsActive, StockQuantity), Mode=OneWay}"
                                                            FontSize="12"
                                                            FontWeight="SemiBold"
                                                            Foreground="{x:Bind local:ProductsPage.GetStatusForeground(IsActive, StockQuantity), Mode=OneWay}" />
                                                    </Border>
                                                </Border>

                                                <!-- Action: pen + trash per row -->
                                                <Border Grid.Column="6" Padding="8,8" BorderBrush="#22000000" BorderThickness="1,0,0,1">
                                                    <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <Button
                                                            Padding="6"
                                                            CornerRadius="6"
                                                            Background="Transparent"
                                                            ToolTipService.ToolTip="Edit product">
                                                            <FontIcon
                                                                FontFamily="Segoe Fluent Icons"
                                                                Glyph="&#xE70F;"
                                                                FontSize="13"
                                                                Foreground="{StaticResource TextSecondary}" />
                                                        </Button>
                                                        <Button
                                                            Padding="6"
                                                            CornerRadius="6"
                                                            Background="Transparent"
                                                            ToolTipService.ToolTip="Delete product">
                                                            <FontIcon
                                                                FontFamily="Segoe Fluent Icons"
                                                                Glyph="&#xE74D;"
                                                                FontSize="13"
                                                                Foreground="#DC2626" />
                                                        </Button>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>

                        <!-- ── Row 5: Footer ── -->
                        <Grid Grid.Row="5" Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Text="{x:Bind ResultText, Mode=OneWay}"
                                    FontSize="13"
                                    Foreground="{StaticResource TextSecondary}" />
                                <ComboBox
                                    x:Name="PageSizeCombo"
                                    Width="75"
                                    ItemsSource="{x:Bind PageSizeOptions, Mode=OneWay}"
                                    SelectionChanged="PageSizeCombo_SelectionChanged"
                                    SelectedItem="{x:Bind SelectedPageSize, Mode=TwoWay}" />
                            </StackPanel>

                            <ItemsControl Grid.Column="2" ItemsSource="{x:Bind PageButtons, Mode=OneWay}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="6" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="local:ProductPageButtonItem">
                                        <Button
                                            MinWidth="36"
                                            Height="32"
                                            Padding="10,0"
                                            Content="{Binding Label}"
                                            Tag="{Binding PageNumber}"
                                            Click="PageButton_Click"
                                            IsEnabled="{Binding IsEnabled}"
                                            Background="{Binding Background}"
                                            Foreground="{Binding Foreground}"
                                            CornerRadius="8" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>

                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
