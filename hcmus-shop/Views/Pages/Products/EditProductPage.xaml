<Page
    x:Class="hcmus_shop.Views.EditProductPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:productVm="using:hcmus_shop.ViewModels.Products"
    x:Name="Root">

    <Grid Background="{StaticResource DashboardBackground}">
        <ScrollViewer>
            <Grid Margin="24" RowSpacing="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button
                        Padding="12,8"
                        CornerRadius="8"
                        Click="BackButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE72B;" />
                            <TextBlock Text="Return" />
                        </StackPanel>
                    </Button>

                    <StackPanel
                        Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8">
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE70F;" FontSize="18" Foreground="{StaticResource TextPrimary}" />
                        <TextBlock
                            Text="Edit Product"
                            FontSize="28"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimary}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10">
                        <Button
                            Padding="18,8"
                            CornerRadius="999"
                            Command="{x:Bind ViewModel.DeleteProductCommand}"
                            Background="{StaticResource DangerBackgroundSubtle}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE74D;" Foreground="{StaticResource DangerForeground}" />
                                <TextBlock Text="Delete" FontWeight="SemiBold" Foreground="{StaticResource DangerForeground}" />
                            </StackPanel>
                        </Button>

                        <Button
                            Padding="18,8"
                            CornerRadius="999"
                            Command="{x:Bind ViewModel.SaveProductCommand}"
                            Background="{StaticResource LoginPrimaryBrush}"
                            Foreground="White">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE73E;" />
                                <TextBlock Text="Save Changes" FontWeight="SemiBold" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.65*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        Margin="0,0,0,10"
                        Text="{x:Bind ViewModel.SaveErrorMessage, Mode=OneWay}"
                        Foreground="{StaticResource DangerForeground}" />

                    <TextBlock
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        Margin="0,22,0,10"
                        Text="{x:Bind ViewModel.SaveStatusMessage, Mode=OneWay}"
                        Foreground="{StaticResource TextSecondary}"
                        Visibility="{x:Bind ViewModel.HasSaveStatus, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />

                    <Grid RowSpacing="16">
                        <Grid.Margin>0,26,0,0</Grid.Margin>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border
                            Background="{StaticResource CardBackground}"
                            CornerRadius="16"
                            Padding="16">
                            <Grid RowSpacing="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="General Information" FontSize="26" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" />

                                <Grid Grid.Row="1" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid RowSpacing="6">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="SKU" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" />
                                        <TextBox Grid.Row="1" Text="{x:Bind ViewModel.Sku, Mode=TwoWay}" PlaceholderText="SKU" />
                                    </Grid>
                                    <Grid Grid.Column="1" RowSpacing="6">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="Name Product" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" />
                                        <TextBox Grid.Row="1" Text="{x:Bind ViewModel.Name, Mode=TwoWay}" />
                                    </Grid>
                                </Grid>

                                <Grid Grid.Row="2" RowSpacing="6">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Description Product" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" />
                                    <TextBox
                                        Grid.Row="1"
                                        Text="{x:Bind ViewModel.Description, Mode=TwoWay}"
                                        TextWrapping="Wrap"
                                        AcceptsReturn="True"
                                        MinHeight="110" />
                                </Grid>

                                <Grid Grid.Row="3" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid RowSpacing="6">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="Brand" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" />
                                        <ComboBox
                                            Grid.Row="1"
                                            ItemsSource="{x:Bind ViewModel.BrandOptions, Mode=OneWay}"
                                            DisplayMemberPath="Name"
                                            SelectedValuePath="Id"
                                            SelectedValue="{x:Bind ViewModel.SelectedBrandId, Mode=TwoWay}" />
                                    </Grid>
                                    <Grid Grid.Column="1" RowSpacing="6">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="Series (Optional)" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" />
                                        <ComboBox
                                            Grid.Row="1"
                                            ItemsSource="{x:Bind ViewModel.SeriesOptions, Mode=OneWay}"
                                            DisplayMemberPath="Name"
                                            SelectedValuePath="Id"
                                            SelectedValue="{x:Bind ViewModel.SelectedSeriesId, Mode=TwoWay}" />
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border
                            Grid.Row="1"
                            Background="{StaticResource CardBackground}"
                            CornerRadius="16"
                            Padding="16">
                            <Grid RowSpacing="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="Pricing And Status" FontSize="26" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" />

                                <Grid Grid.Row="1" ColumnSpacing="12" RowSpacing="10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="Import Price" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" />
                                    <TextBlock Grid.Column="1" Text="Selling Price" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" />

                                    <NumberBox
                                        Grid.Row="1"
                                        Value="{x:Bind ViewModel.ImportPriceValue, Mode=TwoWay}"
                                        SpinButtonPlacementMode="Inline"
                                        Minimum="0" />
                                    <NumberBox
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Value="{x:Bind ViewModel.SellingPriceValue, Mode=TwoWay}"
                                        SpinButtonPlacementMode="Inline"
                                        Minimum="0" />

                                    <TextBlock
                                        Grid.Row="2"
                                        Text="Stock Quantity"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource TextPrimary}" />

                                    <NumberBox
                                        Grid.Row="3"
                                        Value="{x:Bind ViewModel.StockQuantityValue, Mode=TwoWay}"
                                        SpinButtonPlacementMode="Inline"
                                        Minimum="0" />

                                    <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="24">
                                        <StackPanel Orientation="Vertical" Spacing="6">
                                            <TextBlock Text="Warranty Months" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" />
                                            <NumberBox
                                                Width="180"
                                                Value="{x:Bind ViewModel.WarrantyMonthsValue, Mode=TwoWay}"
                                                SpinButtonPlacementMode="Inline"
                                                Minimum="0" />
                                        </StackPanel>

                                        <StackPanel Orientation="Vertical" Spacing="6">
                                            <TextBlock Text="Active Status" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" />
                                            <ToggleSwitch
                                                OffContent="Inactive"
                                                OnContent="Active"
                                                IsOn="{x:Bind ViewModel.IsActive, Mode=TwoWay}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid Grid.Column="1" RowSpacing="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border
                            Background="{StaticResource CardBackground}"
                            CornerRadius="16"
                            Padding="16">
                            <Grid RowSpacing="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="Image URLs" FontSize="26" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" />

                                <Grid Grid.Row="1" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox
                                        PlaceholderText="https://... or /uploads/products/..."
                                        Text="{x:Bind ViewModel.NewImageUrl, Mode=TwoWay}" />
                                    <Button
                                        Grid.Column="1"
                                        Padding="12,8"
                                        Command="{x:Bind ViewModel.AddImageUrlCommand}"
                                        Content="Add" />
                                </Grid>

                                <StackPanel Grid.Row="2" Spacing="8">
                                    <Button
                                        HorizontalAlignment="Left"
                                        Padding="12,8"
                                        Click="PickLocalImagesButton_Click"
                                        Content="Pick Local Images" />

                                    <ItemsControl ItemsSource="{x:Bind ViewModel.PendingImageFiles, Mode=OneWay}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="productVm:PendingImageFileViewModel">
                                                <Grid Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock
                                                        Text="{x:Bind Name, Mode=OneWay}"
                                                        VerticalAlignment="Center"
                                                        Foreground="{StaticResource TextSecondary}" />
                                                    <Button
                                                        Grid.Column="1"
                                                        Margin="8,0,0,0"
                                                        Padding="8,4"
                                                        Click="RemovePendingImageButton_Click"
                                                        Tag="{x:Bind}">
                                                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE74D;" Foreground="{StaticResource DangerForeground}" />
                                                    </Button>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <ItemsControl ItemsSource="{x:Bind ViewModel.ImageUrls, Mode=OneWay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock
                                                    Text="{x:Bind}"
                                                    TextWrapping="WrapWholeWords"
                                                    VerticalAlignment="Center"
                                                    Foreground="{StaticResource TextPrimary}" />
                                                <Button
                                                    Grid.Column="1"
                                                    Margin="8,0,0,0"
                                                    Padding="8,4"
                                                    Command="{Binding DataContext.RemoveImageUrlCommand, ElementName=Root}"
                                                    CommandParameter="{x:Bind}">
                                                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE74D;" Foreground="{StaticResource DangerForeground}" />
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border
                            Grid.Row="1"
                            Background="{StaticResource CardBackground}"
                            CornerRadius="16"
                            Padding="16">
                            <Grid RowSpacing="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="Category" FontSize="26" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" />

                                <ItemsControl Grid.Row="1" ItemsSource="{x:Bind ViewModel.CategoryOptions, Mode=OneWay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="productVm:CategoryOptionViewModel">
                                            <CheckBox
                                                Margin="0,0,0,6"
                                                Content="{x:Bind Name, Mode=OneWay}"
                                                IsChecked="{x:Bind IsSelected, Mode=TwoWay}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </ScrollViewer>

        <Border
            Background="#66FFFFFF"
            Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ProgressRing
                IsActive="True"
                Width="40"
                Height="40"
                HorizontalAlignment="Center"
                VerticalAlignment="Center" />
        </Border>
    </Grid>
</Page>
