<Page
    x:Class="hcmus_shop.Views.AddProductPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:hcmus_shop.ViewModels"
    xmlns:productVm="using:hcmus_shop.ViewModels.Products"
    x:Name="Root">

    <Grid Background="{StaticResource DashboardBackground}">
        <ScrollViewer>
            <Grid Margin="24" RowSpacing="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button
                        Padding="12,8"
                        CornerRadius="8"
                        Click="BackButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE72B;" />
                            <TextBlock Text="Return" />
                        </StackPanel>
                    </Button>

                    <StackPanel
                        Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8">
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xEC8A;" FontSize="18" Foreground="{StaticResource TextPrimary}" />
                        <TextBlock
                            Text="Add New Product"
                            FontSize="28"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimary}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10">
                        <Button Padding="18,8" CornerRadius="999">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE70B;" />
                                <TextBlock Text="Save Draft" FontWeight="SemiBold" />
                            </StackPanel>
                        </Button>

                        <Button
                            Padding="18,8"
                            CornerRadius="999"
                            Command="{x:Bind ViewModel.SaveProductCommand}"
                            Background="{StaticResource LoginPrimaryBrush}"
                            Foreground="White">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE73E;" />
                                <TextBlock Text="Add Product" FontWeight="SemiBold" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.65*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        Margin="0,0,0,10"
                        Text="{x:Bind ViewModel.SaveErrorMessage, Mode=OneWay}"
                        Foreground="{StaticResource DangerForeground}" />

                    <Grid RowSpacing="16">
                        <Grid.Margin>0,26,0,0</Grid.Margin>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border
                            Background="{StaticResource CardBackground}"
                            CornerRadius="16"
                            Padding="16">
                            <Grid RowSpacing="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="General Information" FontSize="26" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" />

                                <Grid Grid.Row="1" RowSpacing="6">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="SKU" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" />
                                    <TextBox Grid.Row="1" Text="{x:Bind ViewModel.DraftProduct.Sku, Mode=TwoWay}" PlaceholderText="SKU" />
                                </Grid>

                                <Grid Grid.Row="2" RowSpacing="6">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Name Product" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" />
                                    <TextBox Grid.Row="1" Text="{x:Bind ViewModel.DraftProduct.Name, Mode=TwoWay}" />
                                </Grid>

                                <Grid Grid.Row="3" RowSpacing="6">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Description Product" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" />
                                    <TextBox
                                        Grid.Row="1"
                                        Text="{x:Bind ViewModel.DraftProduct.Description, Mode=TwoWay}"
                                        TextWrapping="Wrap"
                                        AcceptsReturn="True"
                                        MinHeight="110" />
                                </Grid>

                                <Grid Grid.Row="4" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Grid RowSpacing="6">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="Brand" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" />
                                        <ComboBox
                                            Grid.Row="1"
                                            PlaceholderText="Select brand"
                                            ItemsSource="{x:Bind ViewModel.BrandOptions, Mode=OneWay}"
                                            DisplayMemberPath="Name"
                                            SelectedValuePath="Id"
                                            SelectedValue="{x:Bind ViewModel.SelectedBrandId, Mode=TwoWay}" />
                                    </Grid>

                                    <Grid Grid.Column="1" RowSpacing="6">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="Series (Optional)" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" />
                                        <ComboBox
                                            Grid.Row="1"
                                            PlaceholderText="Select series"
                                            ItemsSource="{x:Bind ViewModel.SeriesOptions, Mode=OneWay}"
                                            DisplayMemberPath="Name"
                                            SelectedValuePath="Id"
                                            SelectedValue="{x:Bind ViewModel.SelectedSeriesId, Mode=TwoWay}" />
                                    </Grid>
                                </Grid>

                                <Grid Grid.Row="5" RowSpacing="10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="Specifications (JSONB)" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" />
                                    <TextBox
                                        Grid.Row="1"
                                        Text="{x:Bind ViewModel.DraftProduct.Specifications, Mode=TwoWay}"
                                        TextWrapping="Wrap"
                                        AcceptsReturn="True"
                                        MinHeight="120"
                                        PlaceholderText="Enter JSON specifications" />

                                    <TextBlock Grid.Row="2" Text="Warranty Months" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" />
                                    <NumberBox
                                        Grid.Row="3"
                                        Value="{x:Bind ViewModel.WarrantyMonthsValue, Mode=TwoWay}"
                                        SpinButtonPlacementMode="Inline"
                                        Minimum="0" />
                                </Grid>
                            </Grid>
                        </Border>

                        <Border
                            Grid.Row="1"
                            Background="{StaticResource CardBackground}"
                            CornerRadius="16"
                            Padding="16">
                            <Grid RowSpacing="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="Pricing And Stock" FontSize="26" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" />

                                <Grid Grid.Row="1" ColumnSpacing="12" RowSpacing="10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="Import Price" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" />
                                    <TextBlock Grid.Column="1" Text="Selling Price" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" />

                                    <NumberBox
                                        Grid.Row="1"
                                        Value="{x:Bind ViewModel.ImportPriceValue, Mode=TwoWay}"
                                        SpinButtonPlacementMode="Inline"
                                        Minimum="0" />

                                    <NumberBox
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Value="{x:Bind ViewModel.SellingPriceValue, Mode=TwoWay}"
                                        SpinButtonPlacementMode="Inline"
                                        Minimum="0" />
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid Grid.Column="1" RowSpacing="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border
                            Background="{StaticResource CardBackground}"
                            CornerRadius="16"
                            Padding="16">
                            <Grid RowSpacing="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="Upload Img" FontSize="26" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" />

                                <Border
                                    Grid.Row="1"
                                    CornerRadius="12"
                                    Background="#FFEAF4E8"
                                    BorderBrush="#22000000"
                                    BorderThickness="1"
                                    MinHeight="290"
                                    Padding="8">
                                    <Grid>
                                        <Image
                                            Source="{x:Bind ViewModel.MainPreview.Bitmap, Mode=OneWay}"
                                            Stretch="UniformToFill"
                                            Visibility="{x:Bind ViewModel.HasMainPreview, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                        <StackPanel
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Spacing="10"
                                            Visibility="{x:Bind ViewModel.HasMainPreview, Mode=OneWay, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                            <Border
                                                Width="110"
                                                Height="110"
                                                CornerRadius="55"
                                                Background="#FFDCF0D9">
                                                <FontIcon
                                                    FontFamily="Segoe Fluent Icons"
                                                    Glyph="&#xEC8A;"
                                                    FontSize="48"
                                                    Foreground="{StaticResource LoginPrimaryBrush}"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center" />
                                            </Border>
                                            <TextBlock Text="Main image preview" Foreground="{StaticResource TextSecondary}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Grid Grid.Row="2" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Button
                                        Width="72"
                                        Height="72"
                                        CornerRadius="8"
                                        Click="AddImageButton_Click"
                                        Background="#FFE7F6E4"
                                        Foreground="{StaticResource LoginPrimaryBrush}">
                                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE710;" FontSize="18" />
                                    </Button>

                                    <ScrollViewer
                                        Grid.Column="1"
                                        HorizontalScrollBarVisibility="Auto"
                                        VerticalScrollBarVisibility="Disabled"
                                        HorizontalScrollMode="Enabled"
                                        VerticalScrollMode="Disabled"
                                        ZoomMode="Disabled">
                                        <ItemsControl ItemsSource="{x:Bind ViewModel.PreviewImages, Mode=OneWay}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" Spacing="8" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:ImagePreview">
                                                    <Button
                                                        Width="72"
                                                        Height="72"
                                                        Padding="0"
                                                        Background="#FFF1F5F0"
                                                        BorderBrush="#22000000"
                                                        BorderThickness="1"
                                                        CornerRadius="8"
                                                        Command="{Binding DataContext.SelectPreviewCommand, ElementName=Root}"
                                                        CommandParameter="{x:Bind}">
                                                        <Image Source="{x:Bind Bitmap, Mode=OneWay}" Stretch="UniformToFill" />
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border
                            Grid.Row="1"
                            Background="{StaticResource CardBackground}"
                            CornerRadius="16"
                            Padding="16">
                            <Grid RowSpacing="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="Category" FontSize="26" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" />

                                <TextBlock Grid.Row="1" Text="Product Category (Multiple)" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" />

                                <ItemsControl Grid.Row="2" ItemsSource="{x:Bind ViewModel.CategoryOptions, Mode=OneWay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="productVm:CategoryOptionViewModel">
                                            <CheckBox
                                                Margin="0,0,0,6"
                                                Content="{x:Bind Name, Mode=OneWay}"
                                                IsChecked="{x:Bind IsSelected, Mode=TwoWay}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Button
                                    Grid.Row="3"
                                    Margin="0,6,0,0"
                                    Content="{x:Bind ViewModel.AddCategoryButtonText, Mode=OneWay}"
                                    Padding="16,8"
                                    CornerRadius="999"
                                    HorizontalAlignment="Left"
                                    Command="{x:Bind ViewModel.AddCategoryCommand}"
                                    Background="{StaticResource LoginPrimaryBrush}"
                                    Foreground="White" />

                                <TextBlock
                                    Grid.Row="3"
                                    Margin="150,12,0,0"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource TextSecondary}"
                                    Text="Working..."
                                    Visibility="{x:Bind ViewModel.IsAddingCategory, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                <TextBlock
                                    Grid.Row="3"
                                    Margin="0,44,0,0"
                                    Foreground="{StaticResource DangerForeground}"
                                    Text="{x:Bind ViewModel.CategoryErrorMessage, Mode=OneWay}"
                                    Visibility="{x:Bind ViewModel.HasCategoryError, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
