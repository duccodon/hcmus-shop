<Page
    x:Class="hcmus_shop.Views.Dashboard.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:hcmus_shop.Views.Dashboard.Components.Controls"
    xmlns:charts="using:hcmus_shop.Views.Dashboard.Components.Charts"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    xmlns:dto="using:hcmus_shop.Models.DTOs"
    xmlns:local="using:hcmus_shop.Views.Dashboard"
    x:Name="Root">

    <Grid Background="{StaticResource DashboardBackground}">
        <ScrollViewer>
            <Grid Margin="24" RowSpacing="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <controls:HeaderBar WelcomeText="{x:Bind ViewModel.WelcomeMessage, Mode=OneWay}" />

                <Grid Grid.Row="1" ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <controls:KpiCard
                        Grid.Column="0"
                        Title="{x:Bind ViewModel.KpiCards[0].Title, Mode=OneWay}"
                        Value="{x:Bind ViewModel.KpiCards[0].Value, Mode=OneWay}"
                        DeltaText="{x:Bind ViewModel.KpiCards[0].DeltaText, Mode=OneWay}"
                        Glyph="{x:Bind ViewModel.KpiCards[0].Glyph, Mode=OneWay}"
                        IsPositive="{x:Bind ViewModel.KpiCards[0].IsPositive, Mode=OneWay}" />

                    <controls:KpiCard
                        Grid.Column="1"
                        Title="{x:Bind ViewModel.KpiCards[1].Title, Mode=OneWay}"
                        Value="{x:Bind ViewModel.KpiCards[1].Value, Mode=OneWay}"
                        DeltaText="{x:Bind ViewModel.KpiCards[1].DeltaText, Mode=OneWay}"
                        Glyph="{x:Bind ViewModel.KpiCards[1].Glyph, Mode=OneWay}"
                        IsPositive="{x:Bind ViewModel.KpiCards[1].IsPositive, Mode=OneWay}" />

                    <controls:KpiCard
                        Grid.Column="2"
                        Title="{x:Bind ViewModel.KpiCards[2].Title, Mode=OneWay}"
                        Value="{x:Bind ViewModel.KpiCards[2].Value, Mode=OneWay}"
                        DeltaText="{x:Bind ViewModel.KpiCards[2].DeltaText, Mode=OneWay}"
                        Glyph="{x:Bind ViewModel.KpiCards[2].Glyph, Mode=OneWay}"
                        IsPositive="{x:Bind ViewModel.KpiCards[2].IsPositive, Mode=OneWay}" />

                    <controls:KpiCard
                        Grid.Column="3"
                        Title="{x:Bind ViewModel.KpiCards[3].Title, Mode=OneWay}"
                        Value="{x:Bind ViewModel.KpiCards[3].Value, Mode=OneWay}"
                        DeltaText="{x:Bind ViewModel.KpiCards[3].DeltaText, Mode=OneWay}"
                        Glyph="{x:Bind ViewModel.KpiCards[3].Glyph, Mode=OneWay}"
                        IsPositive="{x:Bind ViewModel.KpiCards[3].IsPositive, Mode=OneWay}" />
                </Grid>

                <Grid Grid.Row="2" ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="3*" />
                    </Grid.ColumnDefinitions>

                    <charts:InvoiceStatsCard
                        Legends="{x:Bind ViewModel.InvoiceLegends, Mode=OneWay}"
                        Series="{x:Bind ViewModel.InvoiceSeries, Mode=OneWay}" />

                    <charts:SalesAnalyticsCard
                        Grid.Column="1"
                        Series="{x:Bind ViewModel.SalesSeries, Mode=OneWay}"
                        XAxes="{x:Bind ViewModel.SalesXAxes, Mode=OneWay}"
                        YAxes="{x:Bind ViewModel.SalesYAxes, Mode=OneWay}" />
                </Grid>

                <Border Grid.Row="3" Background="{StaticResource CardBackground}" CornerRadius="16" Padding="20">
                    <Grid RowSpacing="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Reports" Style="{StaticResource PageTitleStyle}" />
                        <Border Grid.Row="1" Height="1" Background="{StaticResource DividerBrush}" />

                        <Grid Grid.Row="2" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" Text="View range" Style="{StaticResource BodySecondaryTextStyle}" />
                            <DatePicker Grid.Column="1" Date="{x:Bind ReportViewModel.FromDate, Mode=TwoWay}" />
                            <DatePicker Grid.Column="2" Date="{x:Bind ReportViewModel.ToDate, Mode=TwoWay}" />
                            <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="Group by" Style="{StaticResource BodySecondaryTextStyle}" />
                            <ComboBox
                                Grid.Column="4"
                                Width="120"
                                Style="{StaticResource FormComboBoxStyle}"
                                ItemsSource="{x:Bind ReportViewModel.GroupByOptions, Mode=OneWay}"
                                SelectedItem="{x:Bind ReportViewModel.SelectedGroupBy, Mode=TwoWay}" />
                            <StackPanel Grid.Column="5" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind ReportViewModel.LastUpdatedText, Mode=OneWay}" Style="{StaticResource BodySecondaryTextStyle}" />
                                <Button Content="Refresh" Style="{StaticResource PrimaryButtonStyle}" Command="{x:Bind ReportViewModel.RefreshCommand}" />
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="3" RowSpacing="16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Background="{StaticResource SelectionHighlight}" CornerRadius="16" Padding="16">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="Products Sold" Style="{StaticResource CardTitleStyle}" />
                                    <lvc:CartesianChart Height="240" LegendPosition="Top" Series="{x:Bind ReportViewModel.QuantitySeries, Mode=OneWay}" XAxes="{x:Bind ReportViewModel.PeriodAxes, Mode=OneWay}" YAxes="{x:Bind ReportViewModel.QuantityAxes, Mode=OneWay}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Background="{StaticResource SelectionHighlight}" CornerRadius="16" Padding="16">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="Revenue" Style="{StaticResource CardTitleStyle}" />
                                    <lvc:CartesianChart Height="240" LegendPosition="Top" Series="{x:Bind ReportViewModel.RevenueSeries, Mode=OneWay}" XAxes="{x:Bind ReportViewModel.PeriodAxes, Mode=OneWay}" YAxes="{x:Bind ReportViewModel.CurrencyAxes, Mode=OneWay}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="2" Background="{StaticResource SelectionHighlight}" CornerRadius="16" Padding="16">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="Profit" Style="{StaticResource CardTitleStyle}" />
                                    <lvc:CartesianChart Height="240" LegendPosition="Top" Series="{x:Bind ReportViewModel.ProfitSeries, Mode=OneWay}" XAxes="{x:Bind ReportViewModel.PeriodAxes, Mode=OneWay}" YAxes="{x:Bind ReportViewModel.CurrencyAxes, Mode=OneWay}" />
                                </StackPanel>
                            </Border>

                            <Grid Grid.Row="3" ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>
                                <Border Background="{StaticResource SelectionHighlight}" CornerRadius="16" Padding="16">
                                    <StackPanel Spacing="12">
                                        <TextBlock Text="Revenue Share" Style="{StaticResource CardTitleStyle}" />
                                        <lvc:PieChart Height="240" LegendPosition="Right" Series="{x:Bind ReportViewModel.RevenueShareSeries, Mode=OneWay}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Background="{StaticResource SelectionHighlight}" CornerRadius="16" Padding="16">
                                    <StackPanel Spacing="12">
                                        <TextBlock Text="Top Products" Style="{StaticResource CardTitleStyle}" />
                                        <ItemsControl ItemsSource="{x:Bind ReportViewModel.TopProducts, Mode=OneWay}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="dto:TopProductEntryDto">
                                                    <Grid Margin="0,0,0,8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{x:Bind Name}" Style="{StaticResource BodyTextStyle}" />
                                                        <TextBlock Grid.Column="1" Text="{x:Bind TotalSold}" Style="{StaticResource BodySecondaryTextStyle}" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Border
                                Grid.RowSpan="4"
                                Background="{StaticResource CardBackground}"
                                Opacity="0.82"
                                Visibility="{x:Bind ReportViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <ProgressRing IsActive="True" Width="36" Height="36" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
