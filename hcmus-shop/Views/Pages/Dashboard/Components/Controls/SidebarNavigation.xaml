<UserControl
    x:Class="hcmus_shop.Views.Dashboard.Components.Controls.SidebarNavigation"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource DashboardSidebarBorderStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <StackPanel Spacing="3">
                <TextBlock
                    FontWeight="Bold"
                    Style="{StaticResource SectionHeaderTextStyle}"
                    Text="DESKBOARD" />
                <TextBlock Style="{StaticResource BodySecondarySmallTextStyle}" Text="Sales Management Platform" />
            </StackPanel>
            <StackPanel
                Grid.Row="1"
                Margin="0,18,0,0"
                Spacing="6">
                <NavigationViewItem Content="Dashboard" Icon="Home" />
                <NavigationViewItem Content="Products" Icon="AllApps" />
                <NavigationViewItem Content="Store" Icon="Shop" />
                <NavigationViewItem Content="Messages" Icon="Mail" />
                <NavigationViewItem Content="Settings" Icon="Setting" />
            </StackPanel>
            <Button
                Grid.Row="2"
                HorizontalAlignment="Stretch"
                Background="{StaticResource SidebarLogoutBackground}"
                Content="Log Out"
                CornerRadius="10"
                Foreground="{StaticResource TextPrimary}" />
        </Grid>
    </Border>
</UserControl>
