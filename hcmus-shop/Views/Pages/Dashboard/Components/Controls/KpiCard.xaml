<UserControl
    x:Class="hcmus_shop.Views.Dashboard.Components.Controls.KpiCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource DashboardCardBorderStyle}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border
                Width="34"
                Height="34"
                Margin="0,0,12,0"
                VerticalAlignment="Top"
                Background="{StaticResource KpiIconBackground}"
                CornerRadius="17">
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontFamily="Segoe MDL2 Assets"
                    Foreground="{StaticResource AccentCyan}"
                    Text="{x:Bind Glyph, Mode=OneWay}" />
            </Border>
            <StackPanel Grid.Column="1" Spacing="4">
                <TextBlock Foreground="{StaticResource TextSecondary}" Text="{x:Bind Title, Mode=OneWay}" />
                <TextBlock Style="{StaticResource PageTitleStyle}" Text="{x:Bind Value, Mode=OneWay}" />
                <TextBlock Foreground="{x:Bind DeltaBrush, Mode=OneWay}" Text="{x:Bind DeltaText, Mode=OneWay}" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
