<UserControl
    x:Class="hcmus_shop.Views.Dashboard.Components.Controls.DashboardCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <LinearGradientBrush x:Key="CardGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0" Color="#F7F7FB" />
            <GradientStop Offset="1" Color="#ECF0FF" />
        </LinearGradientBrush>
    </UserControl.Resources>

    <Grid>
        <Border
            Padding="18"
            Background="{StaticResource CardGradient}"
            BorderBrush="{StaticResource DashboardCardStrokeBrush}"
            BorderThickness="1"
            CornerRadius="20"
            Shadow="{ThemeResource NavigationViewContentBackgroundShadow}">
            <Grid RowDefinitions="Auto,*" RowSpacing="14">
                <Grid
                    ColumnDefinitions="*,Auto"
                    ColumnSpacing="8"
                    RowDefinitions="Auto,Auto">
                    <StackPanel Orientation="Vertical" Spacing="4">
                        <TextBlock
                            Foreground="{StaticResource DashboardCardTitleBrush}"
                            Style="{StaticResource SectionHeaderTextStyle}"
                            Text="{x:Bind Title, Mode=OneWay}" />
                        <TextBlock
                            Foreground="{StaticResource DashboardCardSubtitleBrush}"
                            Style="{StaticResource BodySecondaryTextStyle}"
                            Text="{x:Bind Subtitle, Mode=OneWay}" />
                    </StackPanel>
                    <Border
                        Grid.Row="0"
                        Grid.RowSpan="2"
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Style="{StaticResource DashboardPillBorderStyle}">
                        <TextBlock
                            Foreground="{StaticResource DashboardCardTitleBrush}"
                            Opacity="0.75"
                            Style="{StaticResource BodySecondaryTextStyle}"
                            Text="Details" />
                    </Border>
                </Grid>
                <Border Grid.Row="1" Style="{StaticResource DashboardOverlayBorderStyle}">
                    <ContentPresenter Content="{x:Bind CardContent, Mode=OneWay}" />
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
