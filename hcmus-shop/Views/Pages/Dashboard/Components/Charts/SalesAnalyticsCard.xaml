<UserControl
    x:Class="hcmus_shop.Views.Dashboard.Components.Charts.SalesAnalyticsCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI">
    <Border Style="{StaticResource DashboardCardBorderStyle}">
        <StackPanel Spacing="12">
            <TextBlock Style="{StaticResource SectionHeaderTextStyle}" Text="Sales Analytics" />
            <lvc:CartesianChart
                Height="250"
                LegendPosition="Hidden"
                Series="{x:Bind Series, Mode=OneWay}"
                XAxes="{x:Bind XAxes, Mode=OneWay}"
                YAxes="{x:Bind YAxes, Mode=OneWay}" />
        </StackPanel>
    </Border>
</UserControl>
