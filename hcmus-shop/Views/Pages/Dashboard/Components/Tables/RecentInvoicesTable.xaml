<UserControl
    x:Class="hcmus_shop.Views.Dashboard.Components.Tables.RecentInvoicesTable"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:hcmus_shop.ViewModels"
    x:Name="Root">

    <Border
        Background="{StaticResource CardBackground}"
        CornerRadius="16"
        Padding="16">
        <Grid RowSpacing="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="360" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Search Bar Row -->
            <Grid>
                <StackPanel
                    Orientation="Horizontal"
                    Spacing="8"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center">

                    <ComboBox
                        x:Name="SearchFieldCombo"
                        Width="170"
                        SelectedIndex="0"
                        SelectionChanged="SearchFieldCombo_SelectionChanged">
                        <ComboBoxItem Content="Customer" Tag="Customer" />
                        <ComboBoxItem Content="Product"  Tag="Product" />
                        <ComboBoxItem Content="Date"     Tag="Date" />
                        <ComboBoxItem Content="Invoice No" Tag="No" />
                    </ComboBox>

                    <TextBox
                        x:Name="SearchTextBox"
                        MinWidth="220"
                        PlaceholderText="Type to search"
                        TextChanged="SearchTextBox_TextChanged" />

                    <StackPanel
                        x:Name="DateSearchPanel"
                        Orientation="Horizontal"
                        Spacing="8"
                        Visibility="Collapsed">
                        <CalendarDatePicker
                            x:Name="SearchFromDatePicker"
                            PlaceholderText="From"
                            DateChanged="SearchDatePicker_DateChanged" />
                        <CalendarDatePicker
                            x:Name="SearchToDatePicker"
                            PlaceholderText="To"
                            DateChanged="SearchDatePicker_DateChanged" />
                    </StackPanel>

                </StackPanel>
            </Grid>

            <!-- Column Headers Row -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*" />
                    <ColumnDefinition Width="1.8*" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="1.8*" />
                    <ColumnDefinition Width="1.6*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Padding="10,8" BorderBrush="#26000000" BorderThickness="0,0,0,1">
                    <Button Click="SortHeader_Click" Tag="No" HorizontalAlignment="Center" Padding="0" Background="Transparent" BorderThickness="0">
                        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="No" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" />
                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="{x:Bind NoSortGlyph, Mode=OneWay}" Foreground="{StaticResource TextSecondary}" FontSize="14" />
                        </StackPanel>
                    </Button>
                </Border>

                <Border Grid.Column="1" Padding="10,8" BorderBrush="#26000000" BorderThickness="1,0,0,1">
                    <Button Click="SortHeader_Click" Tag="Customer" HorizontalAlignment="Center" Padding="0" Background="Transparent" BorderThickness="0">
                        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="Customer" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" />
                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="{x:Bind CustomerSortGlyph, Mode=OneWay}" Foreground="{StaticResource TextSecondary}" FontSize="14" />
                        </StackPanel>
                    </Button>
                </Border>

                <Border Grid.Column="2" Padding="10,8" BorderBrush="#26000000" BorderThickness="1,0,0,1">
                    <Button Click="SortHeader_Click" Tag="Product" HorizontalAlignment="Center" Padding="0" Background="Transparent" BorderThickness="0">
                        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="Product" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" />
                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="{x:Bind ProductSortGlyph, Mode=OneWay}" Foreground="{StaticResource TextSecondary}" FontSize="14" />
                        </StackPanel>
                    </Button>
                </Border>

                <Border Grid.Column="3" Padding="10,8" BorderBrush="#26000000" BorderThickness="1,0,0,1">
                    <Button Click="SortHeader_Click" Tag="Date" HorizontalAlignment="Center" Padding="0" Background="Transparent" BorderThickness="0">
                        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="Date" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" />
                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="{x:Bind DateSortGlyph, Mode=OneWay}" Foreground="{StaticResource TextSecondary}" FontSize="14" />
                        </StackPanel>
                    </Button>
                </Border>

                <!-- Status header with filter dropdown -->
                <Border Grid.Column="4" Padding="6,4" BorderBrush="#26000000" BorderThickness="1,0,0,1">
                    <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button Click="SortHeader_Click" Tag="Status" Padding="0" Background="Transparent" BorderThickness="0">
                            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                <TextBlock Text="Status" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" />
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="{x:Bind StatusSortGlyph, Mode=OneWay}" Foreground="{StaticResource TextSecondary}" FontSize="14" />
                            </StackPanel>
                        </Button>
                        <ComboBox
                            x:Name="StatusFilterCombo"
                            Width="100"
                            SelectedIndex="0"
                            SelectionChanged="StatusFilterCombo_SelectionChanged"
                            FontSize="12">
                            <ComboBoxItem Content="All" Tag="" />
                            <ComboBoxItem Content="Paid" Tag="Paid" />
                            <ComboBoxItem Content="Pending" Tag="Pending" />
                            <ComboBoxItem Content="Cancelled" Tag="Cancelled" />
                        </ComboBox>
                    </StackPanel>
                </Border>

                <Border Grid.Column="5" Padding="10,8" BorderBrush="#26000000" BorderThickness="1,0,0,1">
                    <Button Click="SortHeader_Click" Tag="Price" HorizontalAlignment="Center" Padding="0" Background="Transparent" BorderThickness="0">
                        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="Price" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" />
                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="{x:Bind PriceSortGlyph, Mode=OneWay}" Foreground="{StaticResource TextSecondary}" FontSize="14" />
                        </StackPanel>
                    </Button>
                </Border>
            </Grid>

            <!-- Scrollable Table Body -->
            <ScrollViewer
                Grid.Row="2"
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{x:Bind PagedItems, Mode=OneWay}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:RecentInvoiceItem">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.1*" />
                                    <ColumnDefinition Width="1.8*" />
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="1.8*" />
                                    <ColumnDefinition Width="1.6*" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Padding="10,10" BorderBrush="#22000000" BorderThickness="0,0,0,1">
                                    <TextBlock
                                        Text="{Binding No}"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Foreground="{StaticResource TextPrimary}" />
                                </Border>

                                <Border Grid.Column="1" Padding="10,10" BorderBrush="#22000000" BorderThickness="1,0,0,1">
                                    <TextBlock
                                        Text="{Binding Customer}"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Foreground="{StaticResource TextPrimary}" />
                                </Border>

                                <Border Grid.Column="2" Padding="10,10" BorderBrush="#22000000" BorderThickness="1,0,0,1">
                                    <TextBlock
                                        Text="{Binding Product}"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Foreground="{StaticResource TextPrimary}" />
                                </Border>

                                <Border Grid.Column="3" Padding="10,10" BorderBrush="#22000000" BorderThickness="1,0,0,1">
                                    <TextBlock
                                        Text="{Binding Date}"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Foreground="{StaticResource TextPrimary}" />
                                </Border>

                                <!-- Status Badge -->
                                <Border Grid.Column="4" Padding="10,6" BorderBrush="#22000000" BorderThickness="1,0,0,1">
                                    <Border
                                        Background="{Binding StatusBackground}"
                                        CornerRadius="12"
                                        Padding="10,4"
                                        HorizontalAlignment="Center">
                                        <TextBlock
                                            Text="{Binding Status}"
                                            Foreground="{Binding StatusForeground}"
                                            FontWeight="SemiBold"
                                            FontSize="12"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center" />
                                    </Border>
                                </Border>

                                <!-- Price with accent styling -->
                                <Border Grid.Column="5" Padding="10,10" BorderBrush="#22000000" BorderThickness="1,0,0,1">
                                    <TextBlock
                                        Text="{Binding Price}"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource SystemAccentColor}" />
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Pagination Row -->
            <Grid Grid.Row="3" Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    VerticalAlignment="Center"
                    Foreground="{StaticResource TextSecondary}"
                    Text="{x:Bind PagingText, Mode=OneWay}" />

                <!-- Numbered pagination -->
                <ItemsControl
                    Grid.Column="1"
                    ItemsSource="{x:Bind PageButtons, Mode=OneWay}"
                    VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="4" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:PageButtonItem">
                            <Button
                                Content="{Binding Label}"
                                Tag="{Binding PageNumber}"
                                Click="PageButton_Click"
                                IsEnabled="{Binding IsEnabled}"
                                MinWidth="32"
                                Height="32"
                                Padding="4,0"
                                FontWeight="{Binding FontWeight}"
                                Background="{Binding Background}"
                                Foreground="{Binding Foreground}"
                                CornerRadius="6" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Grid>
    </Border>
</UserControl>
