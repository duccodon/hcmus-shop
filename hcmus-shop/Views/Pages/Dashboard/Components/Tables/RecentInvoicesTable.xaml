<UserControl
    x:Class="hcmus_shop.Views.Dashboard.Components.Tables.RecentInvoicesTable"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="using:hcmus_shop.Views.Components.Pagination"
    xmlns:vm="using:hcmus_shop.ViewModels"
    x:Name="Root">

    <Border
        Padding="16"
        Background="{StaticResource CardBackground}"
        CornerRadius="16">
        <Grid RowSpacing="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="360" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  Search Bar Row  -->
            <Grid>
                <StackPanel
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="8">

                    <ComboBox
                        x:Name="SearchFieldCombo"
                        Width="170"
                        SelectedIndex="0"
                        SelectionChanged="SearchFieldCombo_SelectionChanged"
                        Style="{StaticResource FormComboBoxStyle}">
                        <ComboBoxItem Content="Customer" Tag="Customer" />
                        <ComboBoxItem Content="Product" Tag="Product" />
                        <ComboBoxItem Content="Date" Tag="Date" />
                        <ComboBoxItem Content="Invoice No" Tag="No" />
                    </ComboBox>

                    <TextBox
                        x:Name="SearchTextBox"
                        MinWidth="220"
                        PlaceholderText="Type to search"
                        Style="{StaticResource FormTextBoxStyle}"
                        TextChanged="SearchTextBox_TextChanged" />

                    <StackPanel
                        x:Name="DateSearchPanel"
                        Orientation="Horizontal"
                        Spacing="8"
                        Visibility="Collapsed">
                        <CalendarDatePicker
                            x:Name="SearchFromDatePicker"
                            DateChanged="SearchDatePicker_DateChanged"
                            PlaceholderText="From" />
                        <CalendarDatePicker
                            x:Name="SearchToDatePicker"
                            DateChanged="SearchDatePicker_DateChanged"
                            PlaceholderText="To" />
                    </StackPanel>

                </StackPanel>
            </Grid>

            <!--  Column Headers Row  -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*" />
                    <ColumnDefinition Width="1.8*" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="1.8*" />
                    <ColumnDefinition Width="1.6*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    BorderThickness="0,0,0,1"
                    Style="{StaticResource RecentInvoicesHeaderCellStyle}">
                    <Button
                        HorizontalAlignment="Center"
                        BorderThickness="0"
                        Click="SortHeader_Click"
                        Style="{StaticResource GhostButtonStyle}"
                        Tag="No">
                        <StackPanel
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="4">
                            <TextBlock Style="{StaticResource TableHeaderTextStyle}" Text="No" />
                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="{x:Bind NoSortGlyph, Mode=OneWay}" />
                        </StackPanel>
                    </Button>
                </Border>

                <Border
                    Grid.Column="1"
                    BorderThickness="1,0,0,1"
                    Style="{StaticResource RecentInvoicesHeaderCellStyle}">
                    <Button
                        HorizontalAlignment="Center"
                        BorderThickness="0"
                        Click="SortHeader_Click"
                        Style="{StaticResource GhostButtonStyle}"
                        Tag="Customer">
                        <StackPanel
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="4">
                            <TextBlock Style="{StaticResource TableHeaderTextStyle}" Text="Customer" />
                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="{x:Bind CustomerSortGlyph, Mode=OneWay}" />
                        </StackPanel>
                    </Button>
                </Border>

                <Border
                    Grid.Column="2"
                    BorderThickness="1,0,0,1"
                    Style="{StaticResource RecentInvoicesHeaderCellStyle}">
                    <Button
                        HorizontalAlignment="Center"
                        BorderThickness="0"
                        Click="SortHeader_Click"
                        Style="{StaticResource GhostButtonStyle}"
                        Tag="Product">
                        <StackPanel
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="4">
                            <TextBlock Style="{StaticResource TableHeaderTextStyle}" Text="Product" />
                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="{x:Bind ProductSortGlyph, Mode=OneWay}" />
                        </StackPanel>
                    </Button>
                </Border>

                <Border
                    Grid.Column="3"
                    BorderThickness="1,0,0,1"
                    Style="{StaticResource RecentInvoicesHeaderCellStyle}">
                    <Button
                        HorizontalAlignment="Center"
                        BorderThickness="0"
                        Click="SortHeader_Click"
                        Style="{StaticResource GhostButtonStyle}"
                        Tag="Date">
                        <StackPanel
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="4">
                            <TextBlock Style="{StaticResource TableHeaderTextStyle}" Text="Date" />
                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="{x:Bind DateSortGlyph, Mode=OneWay}" />
                        </StackPanel>
                    </Button>
                </Border>

                <!--  Status header with filter dropdown  -->
                <Border
                    Grid.Column="4"
                    Padding="6,4"
                    BorderBrush="{StaticResource TableHeaderBorder}"
                    BorderThickness="1,0,0,1">
                    <Button
                        x:Name="StatusHeaderButton"
                        HorizontalAlignment="Center"
                        BorderThickness="0"
                        Click="StatusHeader_Click"
                        Style="{StaticResource GhostButtonStyle}">
                        <StackPanel
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="4">
                            <TextBlock
                                x:Name="StatusHeaderLabel"
                                Style="{StaticResource TableHeaderTextStyle}"
                                Text="Status: All" />
                            <FontIcon
                                FontFamily="Segoe Fluent Icons"
                                Foreground="{StaticResource TextSecondary}"
                                Glyph="&#xE70D;" />
                        </StackPanel>
                        <Button.Flyout>
                            <MenuFlyout x:Name="StatusMenuFlyout" Placement="Bottom">
                                <MenuFlyoutItem
                                    Click="StatusFilter_Click"
                                    Tag=""
                                    Text="All" />
                                <MenuFlyoutItem
                                    Click="StatusFilter_Click"
                                    Tag="Paid"
                                    Text="Paid" />
                                <MenuFlyoutItem
                                    Click="StatusFilter_Click"
                                    Tag="Pending"
                                    Text="Pending" />
                                <MenuFlyoutItem
                                    Click="StatusFilter_Click"
                                    Tag="Cancelled"
                                    Text="Cancelled" />
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                </Border>

                <Border
                    Grid.Column="5"
                    BorderThickness="1,0,0,1"
                    Style="{StaticResource RecentInvoicesHeaderCellStyle}">
                    <Button
                        HorizontalAlignment="Center"
                        BorderThickness="0"
                        Click="SortHeader_Click"
                        Style="{StaticResource GhostButtonStyle}"
                        Tag="Price">
                        <StackPanel
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="4">
                            <TextBlock Style="{StaticResource TableHeaderTextStyle}" Text="Price" />
                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="{x:Bind PriceSortGlyph, Mode=OneWay}" />
                        </StackPanel>
                    </Button>
                </Border>
            </Grid>

            <!--  Scrollable Table Body  -->
            <ScrollViewer
                Grid.Row="2"
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{x:Bind PagedItems, Mode=OneWay}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:RecentInvoiceItem">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.1*" />
                                    <ColumnDefinition Width="1.8*" />
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="1.8*" />
                                    <ColumnDefinition Width="1.6*" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>

                                <Border
                                    Grid.Column="0"
                                    BorderThickness="0,0,0,1"
                                    Style="{StaticResource RecentInvoicesRowCellStyle}">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource BodyTextStyle}"
                                        Text="{Binding No}" />
                                </Border>

                                <Border
                                    Grid.Column="1"
                                    BorderThickness="1,0,0,1"
                                    Style="{StaticResource RecentInvoicesRowCellStyle}">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource BodyTextStyle}"
                                        Text="{Binding Customer}" />
                                </Border>

                                <Border
                                    Grid.Column="2"
                                    BorderThickness="1,0,0,1"
                                    Style="{StaticResource RecentInvoicesRowCellStyle}">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource BodyTextStyle}"
                                        Text="{Binding Product}" />
                                </Border>

                                <Border
                                    Grid.Column="3"
                                    BorderThickness="1,0,0,1"
                                    Style="{StaticResource RecentInvoicesRowCellStyle}">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource BodyTextStyle}"
                                        Text="{Binding Date}" />
                                </Border>

                                <!--  Status Badge  -->
                                <Border
                                    Grid.Column="4"
                                    BorderThickness="1,0,0,1"
                                    Style="{StaticResource RecentInvoicesStatusOuterCellStyle}">
                                    <Border
                                        Padding="10,4"
                                        HorizontalAlignment="Center"
                                        Background="{Binding Status, Converter={StaticResource InvoiceStatusBackgroundConverter}}"
                                        CornerRadius="12">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Foreground="{Binding Status, Converter={StaticResource InvoiceStatusForegroundConverter}}"
                                            Style="{StaticResource StatusBadgeTextStyle}"
                                            Text="{Binding Status}" />
                                    </Border>
                                </Border>

                                <!--  Price with accent styling  -->
                                <Border
                                    Grid.Column="5"
                                    BorderThickness="1,0,0,1"
                                    Style="{StaticResource RecentInvoicesRowCellStyle}">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Foreground="{StaticResource AccentPurple}"
                                        Style="{StaticResource FieldLabelStyle}"
                                        Text="{Binding Price}" />
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <components:PaginationFooter
                Grid.Row="3"
                PageButtonClickCommand="{x:Bind PageButtonClickCommand}"
                PageButtons="{x:Bind PageButtons, Mode=OneWay}"
                PageSizeOptions="{x:Bind PageSizeOptions, Mode=OneWay}"
                ResultText="{x:Bind FooterResultText, Mode=OneWay}"
                SelectedPageSize="{x:Bind SelectedPageSize, Mode=TwoWay}" />
        </Grid>
    </Border>
</UserControl>

