<Page
    x:Class="hcmus_shop.Views.OrderDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dto="using:hcmus_shop.Models.DTOs"
    xmlns:vm="using:hcmus_shop.ViewModels.Orders"
    x:Name="Root">
    <Grid Background="{StaticResource DashboardBackground}">
        <ScrollViewer>
            <Grid Margin="24">
                <Border Background="{StaticResource CardBackground}" CornerRadius="16" Padding="20">
                    <Grid RowSpacing="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button Style="{StaticResource GhostButtonStyle}" Click="BackButton_Click">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE72B;" />
                                    <TextBlock Text="Back to orders" />
                                </StackPanel>
                            </Button>
                            <StackPanel Grid.Column="1" Margin="16,0,0,0" Spacing="4">
                                <TextBlock Text="Order Details" Style="{StaticResource PageTitleStyle}" />
                                <TextBlock Text="{x:Bind ViewModel.SelectedOrderSummary, Mode=OneWay}" Style="{StaticResource BodySecondaryTextStyle}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                                <Button Content="Edit" Style="{StaticResource GhostButtonStyle}" Click="EditButton_Click" />
                                <Button Content="Mark Paid" Style="{StaticResource PrimaryButtonStyle}" Command="{x:Bind ViewModel.MarkPaidCommand}" />
                            </StackPanel>
                        </Grid>

                        <InfoBar
                            Grid.Row="1"
                            IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                            IsClosable="False"
                            Severity="Error"
                            Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" />

                        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
                            <Button Content="Cancel Order" Style="{StaticResource GhostButtonStyle}" Command="{x:Bind ViewModel.CancelOrderCommand}" />
                            <Button Content="Delete Order" Style="{StaticResource GhostButtonStyle}" Click="DeleteButton_Click" Visibility="{x:Bind ViewModel.CanDeleteSelectedOrder, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <Button Content="Print Invoice PDF" Style="{StaticResource GhostButtonStyle}" Command="{x:Bind ViewModel.PrintInvoiceCommand}" />
                        </StackPanel>

                        <ScrollViewer Grid.Row="3">
                            <StackPanel Spacing="12">
                                <Border Background="{StaticResource SelectionHighlight}" CornerRadius="12" Padding="14">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Customer" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBlock Text="{x:Bind ViewModel.SelectedOrderCustomerName, Mode=OneWay}" Style="{StaticResource BodyTextStyle}" />
                                        <TextBlock Text="{x:Bind ViewModel.SelectedOrderCustomerPhone, Mode=OneWay}" Style="{StaticResource BodySecondaryTextStyle}" />
                                        <TextBlock Text="{x:Bind ViewModel.SelectedOrderCustomerEmail, Mode=OneWay}" Style="{StaticResource BodySecondaryTextStyle}" />
                                    </StackPanel>
                                </Border>

                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Background="{StaticResource SelectionHighlight}" CornerRadius="12" Padding="14">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="Subtotal" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBlock Text="{x:Bind ViewModel.SelectedOrderSubtotalDisplay, Mode=OneWay}" Style="{StaticResource BodyTextStyle}" />
                                            <TextBlock Text="Discount" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBlock Text="{x:Bind ViewModel.SelectedOrderDiscountDisplay, Mode=OneWay}" Style="{StaticResource BodyTextStyle}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Background="{StaticResource SelectionHighlight}" CornerRadius="12" Padding="14">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="Final Amount" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBlock Text="{x:Bind ViewModel.SelectedOrderFinalAmountDisplay, Mode=OneWay}" Style="{StaticResource BodyTextStyle}" />
                                            <TextBlock Text="Promotion" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBlock Text="{x:Bind ViewModel.SelectedOrderPromotionCode, Mode=OneWay}" Style="{StaticResource BodyTextStyle}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Border Background="{StaticResource SelectionHighlight}" CornerRadius="12" Padding="14">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Notes" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBlock Text="{x:Bind ViewModel.SelectedOrderNotesDisplay, Mode=OneWay}" Style="{StaticResource BodyTextStyle}" TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="Order Items" Style="{StaticResource FieldLabelStyle}" />
                                <ItemsControl ItemsSource="{x:Bind ViewModel.SelectedOrderDetailItems, Mode=OneWay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="dto:OrderItemDto">
                                            <Border Background="{StaticResource SelectionHighlight}" CornerRadius="10" Padding="10" Margin="0,0,0,8">
                                                <Grid ColumnSpacing="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{x:Bind Instance.Product.Name}" Style="{StaticResource BodyTextStyle}" />
                                                        <TextBlock Text="{x:Bind Instance.SerialNumber}" Style="{StaticResource BodySecondaryTextStyle}" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" Text="{x:Bind vm:OrdersViewModel.FormatCurrency(UnitSalePrice)}" Style="{StaticResource BodyTextStyle}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
