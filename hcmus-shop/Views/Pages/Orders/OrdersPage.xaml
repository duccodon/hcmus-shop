<Page
    x:Class="hcmus_shop.Views.OrdersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="using:hcmus_shop.Views.Components.Pagination"
    xmlns:dto="using:hcmus_shop.Models.DTOs"
    xmlns:vm="using:hcmus_shop.ViewModels.Orders"
    x:Name="Root">
    <Grid Background="{StaticResource DashboardBackground}">
        <ScrollViewer>
            <Grid Margin="24" ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.6*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <Border Background="{StaticResource CardBackground}" CornerRadius="16" Padding="20">
                    <Grid RowSpacing="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Orders" Style="{StaticResource PageTitleStyle}" />
                            <Button Grid.Column="1" Content="+ Create Order" Style="{StaticResource PrimaryButtonStyle}" Command="{x:Bind ViewModel.BeginCreateOrderCommand}" />
                        </Grid>

                        <Border Grid.Row="1" Height="1" Background="{StaticResource DividerBrush}" />

                        <Grid Grid.Row="2" RowSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                PlaceholderText="Search order, customer, or serial"
                                Style="{StaticResource SearchTextBoxStyle}"
                                Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <ComboBox
                                Grid.Column="1"
                                Width="120"
                                Style="{StaticResource FormComboBoxStyle}"
                                ItemsSource="{x:Bind ViewModel.SelectedStatusOptions, Mode=OneWay}"
                                SelectedItem="{x:Bind ViewModel.SelectedStatus, Mode=TwoWay}" />
                            <DatePicker Grid.Column="2" Date="{x:Bind ViewModel.FromDate, Mode=TwoWay}" />
                            <DatePicker Grid.Column="3" Date="{x:Bind ViewModel.ToDate, Mode=TwoWay}" />
                        </Grid>

                        <Grid Grid.Row="3" MinHeight="360">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <InfoBar
                                Grid.RowSpan="2"
                                Margin="0,0,0,12"
                                IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                                IsClosable="False"
                                Severity="Error"
                                Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="0.8*" />
                                    <ColumnDefinition Width="0.9*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource TableHeaderBorderStyle}">
                                    <TextBlock Text="Customer" Style="{StaticResource TableHeaderTextStyle}" />
                                </Border>
                                <Border Grid.Column="1" Style="{StaticResource TableHeaderBorderStyle}" BorderThickness="1,0,0,1">
                                    <TextBlock Text="Created" Style="{StaticResource TableHeaderTextStyle}" />
                                </Border>
                                <Border Grid.Column="2" Style="{StaticResource TableHeaderBorderStyle}" BorderThickness="1,0,0,1">
                                    <TextBlock Text="Status" Style="{StaticResource TableHeaderTextStyle}" />
                                </Border>
                                <Border Grid.Column="3" Style="{StaticResource TableHeaderBorderStyle}" BorderThickness="1,0,0,1">
                                    <TextBlock Text="Amount" Style="{StaticResource TableHeaderTextStyle}" />
                                </Border>
                            </Grid>

                            <ListView
                                Grid.Row="1"
                                ItemsSource="{x:Bind ViewModel.Orders, Mode=OneWay}"
                                SelectedItem="{x:Bind ViewModel.SelectedOrder, Mode=TwoWay}">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="dto:OrderDto">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1*" />
                                                <ColumnDefinition Width="1*" />
                                                <ColumnDefinition Width="0.8*" />
                                                <ColumnDefinition Width="0.9*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Style="{StaticResource TableRowBorderStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="{x:Bind Customer.Name}" Style="{StaticResource BodyTextStyle}" />
                                                    <TextBlock Text="{x:Bind OrderId}" Style="{StaticResource BodySecondaryTextStyle}" />
                                                </StackPanel>
                                            </Border>
                                            <Border Grid.Column="1" Style="{StaticResource TableRowBorderStyle}" BorderThickness="1,0,0,1">
                                                <TextBlock Text="{x:Bind vm:OrdersViewModel.FormatDate(CreatedAt)}" Style="{StaticResource BodyTextStyle}" />
                                            </Border>
                                            <Border Grid.Column="2" Style="{StaticResource TableRowBorderStyle}" BorderThickness="1,0,0,1">
                                                <Border
                                                    Padding="12,6"
                                                    HorizontalAlignment="Left"
                                                    Background="{Binding Status, Converter={StaticResource InvoiceStatusBackgroundConverter}}"
                                                    CornerRadius="10">
                                                    <TextBlock
                                                        Foreground="{Binding Status, Converter={StaticResource InvoiceStatusForegroundConverter}}"
                                                        Style="{StaticResource StatusBadgeTextStyle}"
                                                        Text="{x:Bind Status}" />
                                                </Border>
                                            </Border>
                                            <Border Grid.Column="3" Style="{StaticResource TableRowBorderStyle}" BorderThickness="1,0,0,1">
                                                <TextBlock Text="{x:Bind vm:OrdersViewModel.FormatCurrency(FinalAmount)}" Style="{StaticResource BodyTextStyle}" />
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>

                        <components:PaginationFooter
                            Grid.Row="4"
                            ResultText="{x:Bind ViewModel.ResultText, Mode=OneWay}"
                            PageSizeOptions="{x:Bind ViewModel.PageSizeOptions, Mode=OneWay}"
                            SelectedPageSize="{x:Bind ViewModel.SelectedPageSize, Mode=TwoWay}"
                            PageButtons="{x:Bind ViewModel.PageButtons, Mode=OneWay}"
                            PageButtonClickCommand="{x:Bind ViewModel.GoToPageCommand}" />
                    </Grid>
                </Border>

                <Border Grid.Column="1" Background="{StaticResource CardBackground}" CornerRadius="16" Padding="20">
                    <Grid RowSpacing="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{x:Bind ViewModel.EditorTitle, Mode=OneWay}" Style="{StaticResource CardTitleStyle}" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" Visibility="{x:Bind ViewModel.IsEditorOpen, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Button Content="Save" Style="{StaticResource PrimaryButtonStyle}" Command="{x:Bind ViewModel.SaveOrderCommand}" />
                                <Button Content="Close" Style="{StaticResource GhostButtonStyle}" Command="{x:Bind ViewModel.CancelEditorCommand}" />
                            </StackPanel>
                        </Grid>

                        <InfoBar
                            Grid.Row="1"
                            IsOpen="{x:Bind ViewModel.HasEditorError, Mode=OneWay}"
                            IsClosable="False"
                            Severity="Error"
                            Message="{x:Bind ViewModel.EditorErrorMessage, Mode=OneWay}"
                            Visibility="{x:Bind ViewModel.IsEditorOpen, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />

                        <Grid Grid.Row="2">
                            <Grid Visibility="{x:Bind ViewModel.IsEditorOpen, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <ScrollViewer>
                                    <StackPanel Spacing="12">
                                        <ComboBox
                                            PlaceholderText="Select customer"
                                            Style="{StaticResource FormComboBoxStyle}"
                                            ItemsSource="{x:Bind ViewModel.Customers, Mode=OneWay}"
                                            DisplayMemberPath="Name"
                                            SelectedValuePath="CustomerId"
                                            SelectedValue="{x:Bind ViewModel.EditorCustomerId, Mode=TwoWay}" />
                                        <TextBox
                                            PlaceholderText="Promotion code"
                                            Style="{StaticResource FormTextBoxStyle}"
                                            Text="{x:Bind ViewModel.EditorPromotionCode, Mode=TwoWay}" />
                                        <Button Content="Apply Promotion" Style="{StaticResource GhostButtonStyle}" Command="{x:Bind ViewModel.ApplyPromotionCommand}" />
                                        <TextBlock Text="{x:Bind ViewModel.PromotionSummary, Mode=OneWay}" Style="{StaticResource BodySecondaryTextStyle}" />
                                        <TextBox
                                            PlaceholderText="Notes"
                                            Style="{StaticResource FormTextBoxStyle}"
                                            AcceptsReturn="True"
                                            MinHeight="80"
                                            Text="{x:Bind ViewModel.EditorNotes, Mode=TwoWay}" />
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox
                                                PlaceholderText="Search serial or product"
                                                Style="{StaticResource SearchTextBoxStyle}"
                                                Text="{x:Bind ViewModel.InstanceSearchQuery, Mode=TwoWay}" />
                                            <Button Grid.Column="1" Content="Search" Style="{StaticResource GhostButtonStyle}" Command="{x:Bind ViewModel.SearchInstancesCommand}" />
                                        </Grid>

                                        <Border Background="{StaticResource SelectionHighlight}" CornerRadius="12" Padding="12">
                                            <ItemsControl ItemsSource="{x:Bind ViewModel.AvailableInstances, Mode=OneWay}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:SelectableInstanceViewModel">
                                                        <CheckBox
                                                            Margin="0,0,0,8"
                                                            IsChecked="{x:Bind IsSelected, Mode=TwoWay}">
                                                            <StackPanel>
                                                                <TextBlock Text="{x:Bind ProductName}" Style="{StaticResource BodyTextStyle}" />
                                                                <TextBlock Text="{x:Bind SerialNumber}" Style="{StaticResource BodySecondaryTextStyle}" />
                                                            </StackPanel>
                                                        </CheckBox>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Border>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Subtotal" Style="{StaticResource FieldLabelStyle}" />
                                                <TextBlock Text="{x:Bind ViewModel.EditorSubtotal, Mode=OneWay}" Style="{StaticResource BodyTextStyle}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Final" Style="{StaticResource FieldLabelStyle}" />
                                                <TextBlock Text="{x:Bind ViewModel.EditorFinalAmount, Mode=OneWay}" Style="{StaticResource BodyTextStyle}" />
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>

                            <Grid Visibility="{x:Bind ViewModel.IsEditorOpen, Mode=OneWay, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="{x:Bind ViewModel.SelectedOrderSummary, Mode=OneWay}" Style="{StaticResource BodySecondaryTextStyle}" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button Content="Edit" Style="{StaticResource GhostButtonStyle}" Command="{x:Bind ViewModel.BeginEditOrderCommand}" />
                                        <Button Content="Mark Paid" Style="{StaticResource PrimaryButtonStyle}" Command="{x:Bind ViewModel.MarkPaidCommand}" />
                                        <Button Content="Cancel" Style="{StaticResource GhostButtonStyle}" Command="{x:Bind ViewModel.CancelOrderCommand}" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button
                                            Content="Delete"
                                            Style="{StaticResource GhostButtonStyle}"
                                            Command="{x:Bind ViewModel.DeleteOrderCommand}"
                                            Visibility="{x:Bind ViewModel.CanDeleteSelectedOrder, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <Button Content="Print Invoice PDF" Style="{StaticResource GhostButtonStyle}" Command="{x:Bind ViewModel.PrintInvoiceCommand}" />
                                    </StackPanel>

                                    <ItemsControl ItemsSource="{x:Bind ViewModel.SelectedOrder.OrderItems, Mode=OneWay}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="dto:OrderItemDto">
                                                <Border Background="{StaticResource SelectionHighlight}" CornerRadius="10" Padding="10" Margin="0,0,0,8">
                                                    <StackPanel>
                                                        <TextBlock Text="{x:Bind Instance.Product.Name}" Style="{StaticResource BodyTextStyle}" />
                                                        <TextBlock Text="{x:Bind Instance.SerialNumber}" Style="{StaticResource BodySecondaryTextStyle}" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
