<Page
    x:Class="hcmus_shop.Views.OrdersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="using:hcmus_shop.Views.Components.Pagination"
    xmlns:dto="using:hcmus_shop.Models.DTOs"
    xmlns:vm="using:hcmus_shop.ViewModels.Orders"
    x:Name="Root">
    <Page.Resources>
        <Style x:Key="OrdersTableListViewItemStyle" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="UseSystemFocusVisuals" Value="False" />
        </Style>
    </Page.Resources>
    <Grid Background="{StaticResource DashboardBackground}">
        <ScrollViewer>
            <Grid Margin="24">
                <Border Background="{StaticResource CardBackground}" CornerRadius="16" Padding="20">
                    <Grid RowSpacing="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Orders" Style="{StaticResource PageTitleStyle}" />
                                <TextBlock Text="Track order history, open details, and create a new sale from a dedicated workspace." Style="{StaticResource BodySecondaryTextStyle}" />
                            </StackPanel>
                            <Button Grid.Column="1" Content="+ Create Order" Style="{StaticResource PrimaryButtonStyle}" Click="CreateOrderButton_Click" />
                        </Grid>

                        <Border Grid.Row="1" Height="1" Background="{StaticResource DividerBrush}" />

                        <Grid Grid.Row="2" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                PlaceholderText="Search order, customer, or serial"
                                Style="{StaticResource SearchTextBoxStyle}"
                                Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <ComboBox
                                Grid.Column="1"
                                Style="{StaticResource FormComboBoxStyle}"
                                ItemsSource="{x:Bind ViewModel.SortFieldOptions, Mode=OneWay}"
                                SelectedItem="{x:Bind ViewModel.SelectedSortField, Mode=TwoWay}"
                                DisplayMemberPath="Label" />
                            <ComboBox
                                Grid.Column="2"
                                Style="{StaticResource FormComboBoxStyle}"
                                ItemsSource="{x:Bind ViewModel.SortDirectionOptions, Mode=OneWay}"
                                SelectedItem="{x:Bind ViewModel.SelectedSortDirection, Mode=TwoWay}"
                                DisplayMemberPath="Label" />
                            <DatePicker Grid.Column="3" Date="{x:Bind ViewModel.FromDate, Mode=TwoWay}" />
                            <DatePicker Grid.Column="4" Date="{x:Bind ViewModel.ToDate, Mode=TwoWay}" />
                        </Grid>

                        <InfoBar
                            Grid.Row="3"
                            IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                            IsClosable="False"
                            Severity="Error"
                            Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" />

                        <Grid Grid.Row="4" MinHeight="360">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.35*" />
                                    <ColumnDefinition Width="1.05*" />
                                    <ColumnDefinition Width="1.15*" />
                                    <ColumnDefinition Width="0.9*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource TableHeaderBorderStyle}">
                                    <TextBlock Text="Customer" Style="{StaticResource TableHeaderTextStyle}" />
                                </Border>
                                <Border Grid.Column="1" Style="{StaticResource TableHeaderBorderStyle}" BorderThickness="1,0,0,1">
                                    <TextBlock Text="Created" Style="{StaticResource TableHeaderTextStyle}" />
                                </Border>
                                <Border Grid.Column="2" Style="{StaticResource TableHeaderBorderStyle}" BorderThickness="1,0,0,1">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Status" Style="{StaticResource TableHeaderTextStyle}" />
                                        <ComboBox
                                            Width="140"
                                            HorizontalAlignment="Left"
                                            Style="{StaticResource FormComboBoxStyle}"
                                            ItemsSource="{x:Bind ViewModel.SelectedStatusOptions, Mode=OneWay}"
                                            SelectedItem="{x:Bind ViewModel.SelectedStatus, Mode=TwoWay}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="3" Style="{StaticResource TableHeaderBorderStyle}" BorderThickness="1,0,0,1">
                                    <TextBlock Text="Amount" Style="{StaticResource TableHeaderTextStyle}" />
                                </Border>
                            </Grid>

                            <ListView
                                x:Name="OrdersListView"
                                Grid.Row="1"
                                IsItemClickEnabled="True"
                                ItemsSource="{x:Bind ViewModel.Orders, Mode=OneWay}"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                ItemContainerStyle="{StaticResource OrdersTableListViewItemStyle}"
                                ItemClick="OrdersListView_ItemClick"
                                SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="dto:OrderDto">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.35*" />
                                                <ColumnDefinition Width="1.05*" />
                                                <ColumnDefinition Width="1.15*" />
                                                <ColumnDefinition Width="0.9*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Style="{StaticResource TableRowBorderStyle}">
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{x:Bind DisplayCustomerName}" Style="{StaticResource BodyTextStyle}" />
                                                    <TextBlock Text="{x:Bind OrderId}" Style="{StaticResource CaptionSecondaryTextStyle}" />
                                                </StackPanel>
                                            </Border>
                                            <Border Grid.Column="1" Style="{StaticResource TableRowBorderStyle}" BorderThickness="1,0,0,1">
                                                <TextBlock VerticalAlignment="Center" Text="{x:Bind vm:OrdersViewModel.FormatDate(CreatedAt)}" Style="{StaticResource BodyTextStyle}" />
                                            </Border>
                                            <Border Grid.Column="2" Style="{StaticResource TableRowBorderStyle}" BorderThickness="1,0,0,1">
                                                <Border
                                                    Padding="12,6"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Left"
                                                    Background="{Binding Status, Converter={StaticResource InvoiceStatusBackgroundConverter}}"
                                                    CornerRadius="10">
                                                    <TextBlock
                                                        Foreground="{Binding Status, Converter={StaticResource InvoiceStatusForegroundConverter}}"
                                                        Style="{StaticResource StatusBadgeTextStyle}"
                                                        Text="{x:Bind Status}" />
                                                </Border>
                                            </Border>
                                            <Border Grid.Column="3" Style="{StaticResource TableRowBorderStyle}" BorderThickness="1,0,0,1">
                                                <TextBlock VerticalAlignment="Center" Text="{x:Bind vm:OrdersViewModel.FormatCurrency(FinalAmount)}" Style="{StaticResource BodyTextStyle}" />
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>

                        <components:PaginationFooter
                            Grid.Row="5"
                            ResultText="{x:Bind ViewModel.ResultText, Mode=OneWay}"
                            PageSizeOptions="{x:Bind ViewModel.PageSizeOptions, Mode=OneWay}"
                            SelectedPageSize="{x:Bind ViewModel.SelectedPageSize, Mode=TwoWay}"
                            PageButtons="{x:Bind ViewModel.PageButtons, Mode=OneWay}"
                            PageButtonClickCommand="{x:Bind ViewModel.GoToPageCommand}" />
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
