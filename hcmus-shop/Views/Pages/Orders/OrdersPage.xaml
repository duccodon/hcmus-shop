<Page
    x:Class="hcmus_shop.Views.OrdersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="using:hcmus_shop.Views.Components.Pagination"
    xmlns:dto="using:hcmus_shop.Models.DTOs"
    xmlns:vm="using:hcmus_shop.ViewModels.Orders"
    x:Name="Root">
    <Grid Background="{StaticResource DashboardBackground}">
        <ScrollViewer>
            <Grid Margin="24">
                <Grid Visibility="{x:Bind ViewModel.IsEditorOpen, Mode=OneWay, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.6*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <Border Background="{StaticResource CardBackground}" CornerRadius="16" Padding="20">
                        <Grid RowSpacing="14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Orders" Style="{StaticResource PageTitleStyle}" />
                                <Button Grid.Column="1" Content="+ Create Order" Style="{StaticResource PrimaryButtonStyle}" Command="{x:Bind ViewModel.BeginCreateOrderCommand}" />
                            </Grid>

                            <Border Grid.Row="1" Height="1" Background="{StaticResource DividerBrush}" />

                            <Grid Grid.Row="2" RowSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox
                                    PlaceholderText="Search order, customer, or serial"
                                    Style="{StaticResource SearchTextBoxStyle}"
                                    Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <ComboBox
                                    Grid.Column="1"
                                    Style="{StaticResource FormComboBoxStyle}"
                                    ItemsSource="{x:Bind ViewModel.SortFieldOptions, Mode=OneWay}"
                                    SelectedItem="{x:Bind ViewModel.SelectedSortField, Mode=TwoWay}"
                                    DisplayMemberPath="Label" />
                                <ComboBox
                                    Grid.Column="2"
                                    Style="{StaticResource FormComboBoxStyle}"
                                    ItemsSource="{x:Bind ViewModel.SortDirectionOptions, Mode=OneWay}"
                                    SelectedItem="{x:Bind ViewModel.SelectedSortDirection, Mode=TwoWay}"
                                    DisplayMemberPath="Label" />
                                <DatePicker Grid.Column="3" Date="{x:Bind ViewModel.FromDate, Mode=TwoWay}" />
                                <DatePicker Grid.Column="4" Date="{x:Bind ViewModel.ToDate, Mode=TwoWay}" />
                            </Grid>

                            <Grid Grid.Row="3" MinHeight="360">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <InfoBar
                                    Grid.RowSpan="2"
                                    Margin="0,0,0,12"
                                    IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                                    IsClosable="False"
                                    Severity="Error"
                                    Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1*" />
                                        <ColumnDefinition Width="1*" />
                                        <ColumnDefinition Width="1.1*" />
                                        <ColumnDefinition Width="0.9*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource TableHeaderBorderStyle}">
                                        <TextBlock Text="Customer" Style="{StaticResource TableHeaderTextStyle}" />
                                    </Border>
                                    <Border Grid.Column="1" Style="{StaticResource TableHeaderBorderStyle}" BorderThickness="1,0,0,1">
                                        <TextBlock Text="Created" Style="{StaticResource TableHeaderTextStyle}" />
                                    </Border>
                                    <Border Grid.Column="2" Style="{StaticResource TableHeaderBorderStyle}" BorderThickness="1,0,0,1">
                                        <ComboBox
                                            Width="140"
                                            HorizontalAlignment="Stretch"
                                            Style="{StaticResource FormComboBoxStyle}"
                                            ItemsSource="{x:Bind ViewModel.SelectedStatusOptions, Mode=OneWay}"
                                            SelectedItem="{x:Bind ViewModel.SelectedStatus, Mode=TwoWay}" />
                                    </Border>
                                    <Border Grid.Column="3" Style="{StaticResource TableHeaderBorderStyle}" BorderThickness="1,0,0,1">
                                        <TextBlock Text="Amount" Style="{StaticResource TableHeaderTextStyle}" />
                                    </Border>
                                </Grid>

                                <ListView
                                    Grid.Row="1"
                                    ItemsSource="{x:Bind ViewModel.Orders, Mode=OneWay}"
                                    SelectedItem="{x:Bind ViewModel.SelectedOrder, Mode=TwoWay}">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="dto:OrderDto">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="1*" />
                                                    <ColumnDefinition Width="1*" />
                                                    <ColumnDefinition Width="1.1*" />
                                                    <ColumnDefinition Width="0.9*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Style="{StaticResource TableRowBorderStyle}">
                                                    <StackPanel>
                                                        <TextBlock Text="{x:Bind Customer.Name}" Style="{StaticResource BodyTextStyle}" />
                                                        <TextBlock Text="{x:Bind OrderId}" Style="{StaticResource BodySecondaryTextStyle}" />
                                                    </StackPanel>
                                                </Border>
                                                <Border Grid.Column="1" Style="{StaticResource TableRowBorderStyle}" BorderThickness="1,0,0,1">
                                                    <TextBlock Text="{x:Bind vm:OrdersViewModel.FormatDate(CreatedAt)}" Style="{StaticResource BodyTextStyle}" />
                                                </Border>
                                                <Border Grid.Column="2" Style="{StaticResource TableRowBorderStyle}" BorderThickness="1,0,0,1">
                                                    <Border
                                                        Padding="10,5"
                                                        HorizontalAlignment="Left"
                                                        Background="{Binding Status, Converter={StaticResource InvoiceStatusBackgroundConverter}}"
                                                        CornerRadius="8">
                                                        <TextBlock
                                                            Foreground="{Binding Status, Converter={StaticResource InvoiceStatusForegroundConverter}}"
                                                            Style="{StaticResource StatusBadgeTextStyle}"
                                                            Text="{x:Bind Status}" />
                                                    </Border>
                                                </Border>
                                                <Border Grid.Column="3" Style="{StaticResource TableRowBorderStyle}" BorderThickness="1,0,0,1">
                                                    <TextBlock Text="{x:Bind vm:OrdersViewModel.FormatCurrency(FinalAmount)}" Style="{StaticResource BodyTextStyle}" />
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>

                            <components:PaginationFooter
                                Grid.Row="4"
                                ResultText="{x:Bind ViewModel.ResultText, Mode=OneWay}"
                                PageSizeOptions="{x:Bind ViewModel.PageSizeOptions, Mode=OneWay}"
                                SelectedPageSize="{x:Bind ViewModel.SelectedPageSize, Mode=TwoWay}"
                                PageButtons="{x:Bind ViewModel.PageButtons, Mode=OneWay}"
                                PageButtonClickCommand="{x:Bind ViewModel.GoToPageCommand}" />
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Background="{StaticResource CardBackground}" CornerRadius="16" Padding="20">
                        <Grid RowSpacing="14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Order Detail" Style="{StaticResource CardTitleStyle}" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                    <Button Content="Edit" Style="{StaticResource GhostButtonStyle}" Command="{x:Bind ViewModel.BeginEditOrderCommand}" />
                                    <Button Content="Mark Paid" Style="{StaticResource PrimaryButtonStyle}" Command="{x:Bind ViewModel.MarkPaidCommand}" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Grid.Row="1" Text="{x:Bind ViewModel.SelectedOrderSummary, Mode=OneWay}" Style="{StaticResource BodySecondaryTextStyle}" />

                            <ScrollViewer Grid.Row="2">
                                <StackPanel Spacing="12">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button Content="Cancel" Style="{StaticResource GhostButtonStyle}" Command="{x:Bind ViewModel.CancelOrderCommand}" />
                                        <Button
                                            Content="Delete"
                                            Style="{StaticResource GhostButtonStyle}"
                                            Command="{x:Bind ViewModel.DeleteOrderCommand}"
                                            Visibility="{x:Bind ViewModel.CanDeleteSelectedOrder, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <Button Content="Print Invoice PDF" Style="{StaticResource GhostButtonStyle}" Command="{x:Bind ViewModel.PrintInvoiceCommand}" />
                                    </StackPanel>

                                    <Border Background="{StaticResource SelectionHighlight}" CornerRadius="12" Padding="14">
                                        <StackPanel Spacing="8">
                                            <TextBlock Text="Customer" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBlock Text="{x:Bind ViewModel.SelectedOrderCustomerName, Mode=OneWay}" Style="{StaticResource BodyTextStyle}" />
                                            <TextBlock Text="{x:Bind ViewModel.SelectedOrderCustomerPhone, Mode=OneWay}" Style="{StaticResource BodySecondaryTextStyle}" />
                                            <TextBlock Text="{x:Bind ViewModel.SelectedOrderCustomerEmail, Mode=OneWay}" Style="{StaticResource BodySecondaryTextStyle}" />
                                        </StackPanel>
                                    </Border>

                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Background="{StaticResource SelectionHighlight}" CornerRadius="12" Padding="14">
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="Subtotal" Style="{StaticResource FieldLabelStyle}" />
                                                <TextBlock Text="{x:Bind ViewModel.SelectedOrderSubtotalDisplay, Mode=OneWay}" Style="{StaticResource BodyTextStyle}" />
                                                <TextBlock Text="Discount" Style="{StaticResource FieldLabelStyle}" />
                                                <TextBlock Text="{x:Bind ViewModel.SelectedOrderDiscountDisplay, Mode=OneWay}" Style="{StaticResource BodyTextStyle}" />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="1" Background="{StaticResource SelectionHighlight}" CornerRadius="12" Padding="14">
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="Final amount" Style="{StaticResource FieldLabelStyle}" />
                                                <TextBlock Text="{x:Bind ViewModel.SelectedOrderFinalAmountDisplay, Mode=OneWay}" Style="{StaticResource BodyTextStyle}" />
                                                <TextBlock Text="Promotion" Style="{StaticResource FieldLabelStyle}" />
                                                <TextBlock Text="{x:Bind ViewModel.SelectedOrderPromotionCode, Mode=OneWay}" Style="{StaticResource BodyTextStyle}" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <Border Background="{StaticResource SelectionHighlight}" CornerRadius="12" Padding="14">
                                        <StackPanel Spacing="8">
                                            <TextBlock Text="Notes" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBlock Text="{x:Bind ViewModel.SelectedOrderNotesDisplay, Mode=OneWay}" Style="{StaticResource BodyTextStyle}" TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                    </Border>

                                    <TextBlock Text="Order Items" Style="{StaticResource FieldLabelStyle}" />
                                    <ItemsControl ItemsSource="{x:Bind ViewModel.SelectedOrderDetailItems, Mode=OneWay}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="dto:OrderItemDto">
                                                <Border Background="{StaticResource SelectionHighlight}" CornerRadius="10" Padding="10" Margin="0,0,0,8">
                                                    <Grid ColumnSpacing="8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="{x:Bind Instance.Product.Name}" Style="{StaticResource BodyTextStyle}" />
                                                            <TextBlock Text="{x:Bind Instance.SerialNumber}" Style="{StaticResource BodySecondaryTextStyle}" />
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="1" Text="{x:Bind vm:OrdersViewModel.FormatCurrency(UnitSalePrice)}" Style="{StaticResource BodyTextStyle}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>

                <Border
                    Background="{StaticResource CardBackground}"
                    CornerRadius="16"
                    Padding="20"
                    Visibility="{x:Bind ViewModel.IsEditorOpen, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid RowSpacing="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock Text="{x:Bind ViewModel.EditorTitle, Mode=OneWay}" Style="{StaticResource PageTitleStyle}" />
                                <TextBlock Text="{x:Bind ViewModel.AutoSaveStatusText, Mode=OneWay}" Style="{StaticResource BodySecondaryTextStyle}" Visibility="{x:Bind ViewModel.HasAutoSaveStatusText, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                <Button Content="Discard Draft" Style="{StaticResource GhostButtonStyle}" Command="{x:Bind ViewModel.DiscardDraftCommand}" Visibility="{x:Bind ViewModel.IsEditMode, Mode=OneWay, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                <Button Content="Save" Style="{StaticResource PrimaryButtonStyle}" Command="{x:Bind ViewModel.SaveOrderCommand}" />
                                <Button Content="Close" Style="{StaticResource GhostButtonStyle}" Command="{x:Bind ViewModel.CancelEditorCommand}" />
                            </StackPanel>
                        </Grid>

                        <InfoBar
                            Grid.Row="1"
                            IsOpen="{x:Bind ViewModel.HasEditorError, Mode=OneWay}"
                            IsClosable="False"
                            Severity="Error"
                            Message="{x:Bind ViewModel.EditorErrorMessage, Mode=OneWay}" />

                        <Grid Grid.Row="2" ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.8*" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Spacing="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="GIỎ HÀNG:" Style="{StaticResource CardTitleStyle}" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.CartSummaryText, Mode=OneWay}" Style="{StaticResource BodySecondaryTextStyle}" VerticalAlignment="Center" />
                                </Grid>

                                <Border Height="1" Background="{StaticResource DividerBrush}" />

                                <AutoSuggestBox
                                    x:Name="InstanceSuggestBox"
                                    PlaceholderText="Search products by name or SKU"
                                    ItemsSource="{x:Bind ViewModel.ProductSuggestions, Mode=OneWay}"
                                    Text="{x:Bind ViewModel.InstanceSearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    TextChanged="InstanceSuggestBox_TextChanged"
                                    SuggestionChosen="InstanceSuggestBox_SuggestionChosen"
                                    QuerySubmitted="InstanceSuggestBox_QuerySubmitted">
                                    <AutoSuggestBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:OrderProductSuggestionViewModel">
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="{x:Bind DisplayText}" Style="{StaticResource BodyTextStyle}" />
                                                <TextBlock Text="{x:Bind SecondaryText}" Style="{StaticResource BodySecondaryTextStyle}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </AutoSuggestBox.ItemTemplate>
                                </AutoSuggestBox>

                                <TextBlock Text="{x:Bind ViewModel.EditorStatusMessage, Mode=OneWay}" Style="{StaticResource BodySecondaryTextStyle}" Visibility="{x:Bind ViewModel.IsEditorBusy, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                <ScrollViewer MaxHeight="620">
                                    <StackPanel Spacing="12">
                                        <ItemsControl ItemsSource="{x:Bind ViewModel.CartItems, Mode=OneWay}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:OrderCartItemViewModel">
                                                    <Border Background="{StaticResource SelectionHighlight}" CornerRadius="16" Padding="16">
                                                        <Grid ColumnSpacing="12">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Spacing="6">
                                                                <TextBlock Text="{x:Bind ProductName}" Style="{StaticResource BodyTextStyle}" TextWrapping="WrapWholeWords" />
                                                                <TextBlock Text="{x:Bind SerialDisplay}" Style="{StaticResource BodySecondaryTextStyle}" />
                                                                <TextBlock Text="{x:Bind UnitPriceDisplay}" Style="{StaticResource BodySecondaryTextStyle}" />
                                                            </StackPanel>

                                                            <StackPanel Grid.Column="1" Spacing="12" HorizontalAlignment="Right">
                                                                <Border Background="{StaticResource CardBackground}" CornerRadius="12" Padding="8,6">
                                                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                                                        <Button Content="-" Style="{StaticResource GhostButtonStyle}" Command="{Binding DataContext.ViewModel.DecreaseQuantityCommand, ElementName=Root}" CommandParameter="{x:Bind}" />
                                                                        <TextBlock Text="{x:Bind Quantity}" Style="{StaticResource BodyTextStyle}" VerticalAlignment="Center" />
                                                                        <Button Content="+" Style="{StaticResource GhostButtonStyle}" Command="{Binding DataContext.ViewModel.IncreaseQuantityCommand, ElementName=Root}" CommandParameter="{x:Bind}" />
                                                                    </StackPanel>
                                                                </Border>
                                                                <TextBlock Text="{x:Bind LineTotalDisplay}" Style="{StaticResource BodyTextStyle}" HorizontalAlignment="Right" />
                                                                <Button Content="Xóa" Style="{StaticResource GhostButtonStyle}" Command="{Binding DataContext.ViewModel.RemoveCartItemCommand, ElementName=Root}" CommandParameter="{x:Bind}" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <TextBlock
                                            Text="No products selected yet."
                                            Style="{StaticResource BodySecondaryTextStyle}"
                                            Visibility="{x:Bind ViewModel.HasSelectedOrderItems, Mode=OneWay, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                    </StackPanel>
                                </ScrollViewer>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="14">
                                <TextBlock Text="THÔNG TIN ĐƠN HÀNG" Style="{StaticResource CardTitleStyle}" />

                                <Border Background="{StaticResource SelectionHighlight}" CornerRadius="16" Padding="16">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="Customer" Style="{StaticResource FieldLabelStyle}" />
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <ComboBox
                                                Style="{StaticResource FormComboBoxStyle}"
                                                ItemsSource="{x:Bind ViewModel.Customers, Mode=OneWay}"
                                                DisplayMemberPath="Name"
                                                SelectedValuePath="CustomerId"
                                                SelectedValue="{x:Bind ViewModel.EditorCustomerId, Mode=TwoWay}" />
                                            <Button
                                                Grid.Column="1"
                                                Content="+ New customer"
                                                Style="{StaticResource GhostButtonStyle}"
                                                Command="{x:Bind ViewModel.CreateInlineCustomerCommand}" />
                                        </Grid>

                                        <TextBlock Text="Tổng tiền:" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBlock Text="{x:Bind vm:OrdersViewModel.FormatCurrency(ViewModel.EditorSubtotal), Mode=OneWay}" Style="{StaticResource BodyTextStyle}" />

                                        <TextBlock Text="Discount" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBlock Text="{x:Bind vm:OrdersViewModel.FormatCurrency(ViewModel.EditorDiscountAmount), Mode=OneWay}" Style="{StaticResource BodyTextStyle}" />

                                        <TextBlock Text="Final amount" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBlock Text="{x:Bind vm:OrdersViewModel.FormatCurrency(ViewModel.EditorFinalAmount), Mode=OneWay}" Style="{StaticResource BodyTextStyle}" />
                                    </StackPanel>
                                </Border>

                                <Border Background="{StaticResource SelectionHighlight}" CornerRadius="16" Padding="16">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="Ghi chú đơn hàng" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBox
                                            AcceptsReturn="True"
                                            MinHeight="110"
                                            Style="{StaticResource FormTextBoxStyle}"
                                            Text="{x:Bind ViewModel.EditorNotes, Mode=TwoWay}" />

                                        <TextBlock Text="Nhập mã khuyến mãi" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBox
                                            Style="{StaticResource FormTextBoxStyle}"
                                            Text="{x:Bind ViewModel.EditorPromotionCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button Content="Apply promotion" Style="{StaticResource GhostButtonStyle}" Command="{x:Bind ViewModel.ApplyPromotionCommand}" />
                                        <TextBlock Text="{x:Bind ViewModel.PromotionSummary, Mode=OneWay}" Style="{StaticResource BodySecondaryTextStyle}" />
                                    </StackPanel>
                                </Border>

                                <Button Content="THANH TOÁN NGAY" Style="{StaticResource PrimaryButtonStyle}" Command="{x:Bind ViewModel.SaveOrderCommand}" />
                                <Button Content="Continue shopping" Style="{StaticResource GhostButtonStyle}" Command="{x:Bind ViewModel.CancelEditorCommand}" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
