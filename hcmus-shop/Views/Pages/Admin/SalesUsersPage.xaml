<Page
    x:Class="hcmus_shop.Views.Pages.Admin.SalesUsersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="using:hcmus_shop.Views.Components.Pagination"
    xmlns:dto="using:hcmus_shop.Models.DTOs"
    x:Name="Root">
    <Grid Background="{StaticResource DashboardBackground}">
        <ScrollViewer>
            <Grid Margin="24">
                <Border Background="{StaticResource CardBackground}" CornerRadius="16" Padding="20">
                    <Grid RowSpacing="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Sales Users" Style="{StaticResource PageTitleStyle}" />
                                <TextBlock Text="Manage sales accounts, credentials, and onboarding-ready access from one table." Style="{StaticResource BodySecondaryTextStyle}" />
                            </StackPanel>
                            <Button Grid.Column="1" Content="+ Add Sales User" Style="{StaticResource PrimaryButtonStyle}" Command="{x:Bind ViewModel.AddUserCommand}" />
                        </Grid>

                        <Border Grid.Row="1" Height="1" Background="{StaticResource DividerBrush}" />

                        <Grid Grid.Row="2" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MaxWidth="320" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                PlaceholderText="Search by username or full name"
                                Style="{StaticResource SearchTextBoxStyle}"
                                Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="1" Content="Refresh" Style="{StaticResource GhostButtonStyle}" Command="{x:Bind ViewModel.RefreshCommand}" />
                        </Grid>

                        <InfoBar
                            Grid.Row="3"
                            IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                            IsClosable="False"
                            Severity="Error"
                            Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" />

                        <Grid Grid.Row="4" MinHeight="320">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.1*" />
                                    <ColumnDefinition Width="1.4*" />
                                    <ColumnDefinition Width="0.9*" />
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="0.9*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource TableHeaderBorderStyle}">
                                    <TextBlock Text="Username" Style="{StaticResource TableHeaderTextStyle}" />
                                </Border>
                                <Border Grid.Column="1" Style="{StaticResource TableHeaderBorderStyle}" BorderThickness="1,0,0,1">
                                    <TextBlock Text="Full Name" Style="{StaticResource TableHeaderTextStyle}" />
                                </Border>
                                <Border Grid.Column="2" Style="{StaticResource TableHeaderBorderStyle}" BorderThickness="1,0,0,1">
                                    <TextBlock Text="Role" Style="{StaticResource TableHeaderTextStyle}" />
                                </Border>
                                <Border Grid.Column="3" Style="{StaticResource TableHeaderBorderStyle}" BorderThickness="1,0,0,1">
                                    <TextBlock Text="Created" Style="{StaticResource TableHeaderTextStyle}" />
                                </Border>
                                <Border Grid.Column="4" Style="{StaticResource TableHeaderBorderStyle}" BorderThickness="1,0,0,1">
                                    <TextBlock Text="Action" Style="{StaticResource TableHeaderTextStyle}" />
                                </Border>
                            </Grid>

                            <ItemsControl Grid.Row="1" ItemsSource="{x:Bind ViewModel.Users, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="dto:UserDto">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.1*" />
                                                <ColumnDefinition Width="1.4*" />
                                                <ColumnDefinition Width="0.9*" />
                                                <ColumnDefinition Width="1*" />
                                                <ColumnDefinition Width="0.9*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Style="{StaticResource TableRowBorderStyle}">
                                                <TextBlock Text="{x:Bind Username}" Style="{StaticResource BodyTextStyle}" />
                                            </Border>
                                            <Border Grid.Column="1" Style="{StaticResource TableRowBorderStyle}" BorderThickness="1,0,0,1">
                                                <TextBlock Text="{x:Bind FullName}" Style="{StaticResource BodyTextStyle}" />
                                            </Border>
                                            <Border Grid.Column="2" Style="{StaticResource TableRowBorderStyle}" BorderThickness="1,0,0,1">
                                                <TextBlock Text="{x:Bind Role}" Style="{StaticResource BodyTextStyle}" />
                                            </Border>
                                            <Border Grid.Column="3" Style="{StaticResource TableRowBorderStyle}" BorderThickness="1,0,0,1">
                                                <TextBlock Text="{x:Bind CreatedAt}" Style="{StaticResource BodySecondaryTextStyle}" />
                                            </Border>
                                            <Border Grid.Column="4" Style="{StaticResource TableRowBorderStyle}" BorderThickness="1,0,0,1">
                                                <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                                    <Button Style="{StaticResource GhostButtonStyle}" Command="{Binding DataContext.ViewModel.EditUserCommand, ElementName=Root}" CommandParameter="{x:Bind}">
                                                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE70F;" />
                                                    </Button>
                                                    <Button Style="{StaticResource GhostButtonStyle}" Command="{Binding DataContext.ViewModel.DeleteUserCommand, ElementName=Root}" CommandParameter="{x:Bind}">
                                                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE74D;" Foreground="{StaticResource DangerForeground}" />
                                                    </Button>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>

                        <components:PaginationFooter
                            Grid.Row="5"
                            ResultText="{x:Bind ViewModel.ResultText, Mode=OneWay}"
                            PageSizeOptions="{x:Bind ViewModel.PageSizeOptions, Mode=OneWay}"
                            SelectedPageSize="{x:Bind ViewModel.SelectedPageSize, Mode=TwoWay}"
                            PageButtons="{x:Bind ViewModel.PageButtons, Mode=OneWay}"
                            PageButtonClickCommand="{x:Bind ViewModel.GoToPageCommand}" />
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
