<Page
    x:Class="hcmus_shop.Views.PromotionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="using:hcmus_shop.Views.Components.Pagination"
    xmlns:vm="using:hcmus_shop.ViewModels.Promotions"
    x:Name="Root">

    <Grid Background="{StaticResource DashboardBackground}">
        <ScrollViewer>
            <Grid Margin="24">
                <Border
                    Background="{StaticResource CardBackground}"
                    CornerRadius="16"
                    Padding="20">
                    <Grid RowSpacing="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                VerticalAlignment="Center"
                                Text="Promotions"
                                Style="{StaticResource PageTitleStyle}" />
                            <Button
                                Grid.Column="1"
                                Content="+ Add Promotion"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{x:Bind ViewModel.AddPromotionCommand}"
                                Visibility="{x:Bind ViewModel.CanManagePromotions, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </Grid>

                        <Border Grid.Row="1" Height="1" Background="{StaticResource DividerBrush}" />

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MaxWidth="320" />
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBox
                                PlaceholderText="Search by code"
                                Style="{StaticResource SearchTextBoxStyle}"
                                Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <ComboBox
                                Grid.Column="1"
                                Style="{StaticResource FormComboBoxStyle}"
                                ItemsSource="{x:Bind ViewModel.SortFieldOptions, Mode=OneWay}"
                                SelectedItem="{x:Bind ViewModel.SelectedSortField, Mode=TwoWay}"
                                DisplayMemberPath="Label" />
                            <ComboBox
                                Grid.Column="2"
                                Style="{StaticResource FormComboBoxStyle}"
                                ItemsSource="{x:Bind ViewModel.SortDirectionOptions, Mode=OneWay}"
                                SelectedItem="{x:Bind ViewModel.SelectedSortDirection, Mode=TwoWay}"
                                DisplayMemberPath="Label" />

                            <StackPanel
                                Grid.Column="3"
                                Orientation="Horizontal"
                                Spacing="8"
                                HorizontalAlignment="Right">
                                <Button
                                    Content="Refresh"
                                    Style="{StaticResource GhostButtonStyle}"
                                    Command="{x:Bind ViewModel.RefreshCommand}" />
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="3" MinHeight="320">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <InfoBar
                                Margin="0,0,0,12"
                                IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                                IsClosable="False"
                                Severity="Error"
                                Visibility="{x:Bind ViewModel.HasError, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                                Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" />

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.3*" />
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="0.9*" />
                                    <ColumnDefinition Width="0.9*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource TableHeaderBorderStyle}">
                                    <TextBlock Text="Code" Style="{StaticResource TableHeaderTextStyle}" />
                                </Border>
                                <Border Grid.Column="1" Style="{StaticResource TableHeaderBorderStyle}" BorderThickness="1,0,0,1">
                                    <TextBlock Text="Discount" Style="{StaticResource TableHeaderTextStyle}" />
                                </Border>
                                <Border Grid.Column="2" Style="{StaticResource TableHeaderBorderStyle}" BorderThickness="1,0,0,1">
                                    <TextBlock Text="Eligible Rank" Style="{StaticResource TableHeaderTextStyle}" />
                                </Border>
                                <Border Grid.Column="3" Style="{StaticResource TableHeaderBorderStyle}" BorderThickness="1,0,0,1">
                                    <TextBlock Text="Start Date" Style="{StaticResource TableHeaderTextStyle}" />
                                </Border>
                                <Border Grid.Column="4" Style="{StaticResource TableHeaderBorderStyle}" BorderThickness="1,0,0,1">
                                    <TextBlock Text="End Date" Style="{StaticResource TableHeaderTextStyle}" />
                                </Border>
                                <Border Grid.Column="5" Style="{StaticResource TableHeaderBorderStyle}" BorderThickness="1,0,0,1">
                                    <ComboBox
                                        Width="120"
                                        Style="{StaticResource FormComboBoxStyle}"
                                        ItemsSource="{x:Bind ViewModel.StatusFilterOptions, Mode=OneWay}"
                                        SelectedItem="{x:Bind ViewModel.SelectedStatusFilter, Mode=TwoWay}" />
                                </Border>
                                <Border Grid.Column="6" Style="{StaticResource TableHeaderBorderStyle}" BorderThickness="1,0,0,1">
                                    <TextBlock Text="Action" Style="{StaticResource TableHeaderTextStyle}" />
                                </Border>
                            </Grid>

                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{x:Bind ViewModel.Promotions, Mode=OneWay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:PromotionListItemViewModel">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="1.3*" />
                                                    <ColumnDefinition Width="1*" />
                                                    <ColumnDefinition Width="1*" />
                                                    <ColumnDefinition Width="1*" />
                                                    <ColumnDefinition Width="1*" />
                                                    <ColumnDefinition Width="0.9*" />
                                                    <ColumnDefinition Width="0.9*" />
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="0" Style="{StaticResource TableRowBorderStyle}">
                                                    <TextBlock VerticalAlignment="Center" Text="{x:Bind Code}" Style="{StaticResource BodyTextStyle}" />
                                                </Border>
                                                <Border Grid.Column="1" Style="{StaticResource TableRowBorderStyle}" BorderThickness="1,0,0,1">
                                                    <TextBlock VerticalAlignment="Center" Text="{x:Bind DiscountDisplay}" Style="{StaticResource BodyTextStyle}" />
                                                </Border>
                                                <Border Grid.Column="2" Style="{StaticResource TableRowBorderStyle}" BorderThickness="1,0,0,1">
                                                    <TextBlock VerticalAlignment="Center" Text="{x:Bind EligibilityDisplay}" Style="{StaticResource BodyTextStyle}" />
                                                </Border>
                                                <Border Grid.Column="3" Style="{StaticResource TableRowBorderStyle}" BorderThickness="1,0,0,1">
                                                    <TextBlock VerticalAlignment="Center" Text="{x:Bind StartDateDisplay}" Style="{StaticResource BodyTextStyle}" />
                                                </Border>
                                                <Border Grid.Column="4" Style="{StaticResource TableRowBorderStyle}" BorderThickness="1,0,0,1">
                                                    <TextBlock VerticalAlignment="Center" Text="{x:Bind EndDateDisplay}" Style="{StaticResource BodyTextStyle}" />
                                                </Border>
                                                <Border Grid.Column="5" Style="{StaticResource TableRowBorderStyle}" BorderThickness="1,0,0,1">
                                                    <Border
                                                        Padding="12,6"
                                                        CornerRadius="10"
                                                        Background="{x:Bind StatusTone, Mode=OneWay, Converter={StaticResource StatusToneBackgroundConverter}}"
                                                        HorizontalAlignment="Left">
                                                        <TextBlock
                                                            Text="{x:Bind StatusText}"
                                                            Style="{StaticResource StatusBadgeTextStyle}"
                                                            Foreground="{x:Bind StatusTone, Mode=OneWay, Converter={StaticResource StatusToneForegroundConverter}}" />
                                                    </Border>
                                                </Border>
                                                <Border Grid.Column="6" Style="{StaticResource TableRowBorderStyle}" BorderThickness="1,0,0,1">
                                                    <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <Button
                                                            Style="{StaticResource GhostButtonStyle}"
                                                            Command="{Binding DataContext.EditPromotionCommand, ElementName=Root}"
                                                            CommandParameter="{x:Bind PromotionId}"
                                                            Visibility="{Binding DataContext.CanManagePromotions, ElementName=Root, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE70F;" />
                                                        </Button>
                                                        <Button
                                                            Style="{StaticResource GhostButtonStyle}"
                                                            Command="{Binding DataContext.DeletePromotionCommand, ElementName=Root}"
                                                            CommandParameter="{x:Bind PromotionId}"
                                                            Visibility="{Binding DataContext.CanManagePromotions, ElementName=Root, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE74D;" Foreground="{StaticResource DangerForeground}" />
                                                        </Button>
                                                        <TextBlock
                                                            Text="View"
                                                            Style="{StaticResource BodySecondaryTextStyle}"
                                                            Visibility="{Binding DataContext.CanManagePromotions, ElementName=Root, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <Border
                                Grid.RowSpan="3"
                                Background="{StaticResource CardBackground}"
                                Opacity="0.85"
                                Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <ProgressRing IsActive="True" Width="36" Height="36" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>

                            <Border
                                Grid.Row="2"
                                Background="Transparent"
                                Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource EmptyStateTextStyle}"
                                    Text="No promotions found." />
                            </Border>
                        </Grid>

                        <components:PaginationFooter
                            Grid.Row="4"
                            ResultText="{x:Bind ViewModel.ResultText, Mode=OneWay}"
                            PageSizeOptions="{x:Bind ViewModel.PageSizeOptions, Mode=OneWay}"
                            SelectedPageSize="{x:Bind ViewModel.SelectedPageSize, Mode=TwoWay}"
                            PageButtons="{x:Bind ViewModel.PageButtons, Mode=OneWay}"
                            PageButtonClickCommand="{x:Bind ViewModel.GoToPageCommand}" />
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
