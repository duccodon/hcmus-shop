<Page
    x:Class="hcmus_shop.Views.CustomersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="using:hcmus_shop.Views.Components.Pagination"
    xmlns:dto="using:hcmus_shop.Models.DTOs"
    x:Name="Root">
    <Grid Background="{StaticResource DashboardBackground}">
        <ScrollViewer>
            <Grid Margin="24">
                <Border Background="{StaticResource CardBackground}" CornerRadius="16" Padding="20">
                    <Grid RowSpacing="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Customers" Style="{StaticResource PageTitleStyle}" />
                                <TextBlock Text="{x:Bind ViewModel.AccessSummary, Mode=OneWay}" Style="{StaticResource BodySecondaryTextStyle}" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <Button Grid.Column="1" Content="+ Add Customer" Style="{StaticResource PrimaryButtonStyle}" Command="{x:Bind ViewModel.AddCustomerCommand}" />
                        </Grid>

                        <Border Grid.Row="1" Height="1" Background="{StaticResource DividerBrush}" />

                        <Grid Grid.Row="2" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MaxWidth="320" />
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                PlaceholderText="Search by name, phone, or email"
                                Style="{StaticResource SearchTextBoxStyle}"
                                Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <ComboBox
                                Grid.Column="1"
                                Style="{StaticResource FormComboBoxStyle}"
                                ItemsSource="{x:Bind ViewModel.SortFieldOptions, Mode=OneWay}"
                                SelectedItem="{x:Bind ViewModel.SelectedSortField, Mode=TwoWay}"
                                DisplayMemberPath="Label" />
                            <ComboBox
                                Grid.Column="2"
                                Style="{StaticResource FormComboBoxStyle}"
                                ItemsSource="{x:Bind ViewModel.SortDirectionOptions, Mode=OneWay}"
                                SelectedItem="{x:Bind ViewModel.SelectedSortDirection, Mode=TwoWay}"
                                DisplayMemberPath="Label" />
                            <Button
                                Grid.Column="3"
                                Content="Refresh"
                                Style="{StaticResource GhostButtonStyle}"
                                Command="{x:Bind ViewModel.RefreshCommand}" />
                        </Grid>

                        <InfoBar
                            Grid.Row="3"
                            IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                            IsClosable="False"
                            Severity="Error"
                            Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" />

                        <Grid Grid.Row="4" MinHeight="320">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.4*" />
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="1.1*" />
                                    <ColumnDefinition Width="0.9*" />
                                    <ColumnDefinition Width="0.9*" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource TableHeaderBorderStyle}">
                                    <TextBlock Text="Customer" Style="{StaticResource TableHeaderTextStyle}" />
                                </Border>
                                <Border Grid.Column="1" Style="{StaticResource TableHeaderBorderStyle}" BorderThickness="1,0,0,1">
                                    <TextBlock Text="Phone" Style="{StaticResource TableHeaderTextStyle}" />
                                </Border>
                                <Border Grid.Column="2" Style="{StaticResource TableHeaderBorderStyle}" BorderThickness="1,0,0,1">
                                    <TextBlock Text="Email" Style="{StaticResource TableHeaderTextStyle}" />
                                </Border>
                                <Border Grid.Column="3" Style="{StaticResource TableHeaderBorderStyle}" BorderThickness="1,0,0,1">
                                    <TextBlock Text="Loyalty Points" Style="{StaticResource TableHeaderTextStyle}" />
                                </Border>
                                <Border Grid.Column="4" Style="{StaticResource TableHeaderBorderStyle}" BorderThickness="1,0,0,1">
                                    <TextBlock Text="Rank" Style="{StaticResource TableHeaderTextStyle}" />
                                </Border>
                                <Border Grid.Column="5" Style="{StaticResource TableHeaderBorderStyle}" BorderThickness="1,0,0,1">
                                    <TextBlock Text="Action" Style="{StaticResource TableHeaderTextStyle}" />
                                </Border>
                            </Grid>

                            <ListView Grid.Row="1"
                                      x:Name="CustomersListView"
                                      ItemsSource="{x:Bind ViewModel.Customers, Mode=OneWay}"
                                      IsItemClickEnabled="True"
                                      ItemClick="CustomersListView_ItemClick"
                                      SelectionMode="None">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="dto:CustomerDto">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="1.4*" />
                                                    <ColumnDefinition Width="1*" />
                                                    <ColumnDefinition Width="1.1*" />
                                                    <ColumnDefinition Width="0.9*" />
                                                    <ColumnDefinition Width="0.9*" />
                                                    <ColumnDefinition Width="1*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Style="{StaticResource TableRowBorderStyle}">
                                                    <TextBlock Text="{x:Bind Name}" Style="{StaticResource BodyTextStyle}" />
                                                </Border>
                                                <Border Grid.Column="1" Style="{StaticResource TableRowBorderStyle}" BorderThickness="1,0,0,1">
                                                    <TextBlock Text="{x:Bind Phone}" Style="{StaticResource BodyTextStyle}" />
                                                </Border>
                                                <Border Grid.Column="2" Style="{StaticResource TableRowBorderStyle}" BorderThickness="1,0,0,1">
                                                    <TextBlock Text="{x:Bind Email}" Style="{StaticResource BodyTextStyle}" />
                                                </Border>
                                                <Border Grid.Column="3" Style="{StaticResource TableRowBorderStyle}" BorderThickness="1,0,0,1">
                                                    <TextBlock Text="{x:Bind LoyaltyPoints, Mode=OneWay}" Style="{StaticResource BodyTextStyle}" />
                                                </Border>
                                                <Border Grid.Column="4" Style="{StaticResource TableRowBorderStyle}" BorderThickness="1,0,0,1">
                                                    <Border Padding="12,6" CornerRadius="10" Background="{StaticResource SelectionHighlight}" HorizontalAlignment="Left">
                                                        <TextBlock Text="{x:Bind Rank}" Style="{StaticResource StatusBadgeTextStyle}" Foreground="{StaticResource TextPrimary}" />
                                                    </Border>
                                                </Border>
                                                <Border Grid.Column="5" Style="{StaticResource TableRowBorderStyle}" BorderThickness="1,0,0,1">
                                                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                                        <Button
                                                            Content="Update"
                                                            Style="{StaticResource GhostButtonStyle}"
                                                            Command="{Binding DataContext.ViewModel.OpenCustomerDetailCommand, ElementName=Root}"
                                                            CommandParameter="{Binding}"
                                                            Visibility="{Binding DataContext.ViewModel.CanViewCustomerDetails, ElementName=Root, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                        <Button
                                                            Style="{StaticResource GhostButtonStyle}"
                                                            Command="{Binding DataContext.ViewModel.DeleteCustomerCommand, ElementName=Root}"
                                                            CommandParameter="{Binding}"
                                                            Visibility="{Binding DataContext.ViewModel.CanDeleteCustomers, ElementName=Root, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE74D;" Foreground="{StaticResource DangerForeground}" />
                                                        </Button>
                                                        <TextBlock
                                                            Text="Order-ready"
                                                            Style="{StaticResource BodySecondaryTextStyle}"
                                                            Visibility="{Binding DataContext.ViewModel.CanViewCustomerDetails, ElementName=Root, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                            </ListView>
                        </Grid>

                        <components:PaginationFooter
                            Grid.Row="5"
                            ResultText="{x:Bind ViewModel.ResultText, Mode=OneWay}"
                            PageSizeOptions="{x:Bind ViewModel.PageSizeOptions, Mode=OneWay}"
                            SelectedPageSize="{x:Bind ViewModel.SelectedPageSize, Mode=TwoWay}"
                            PageButtons="{x:Bind ViewModel.PageButtons, Mode=OneWay}"
                            PageButtonClickCommand="{x:Bind ViewModel.GoToPageCommand}" />
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
