<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="hcmus_shop.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollMode="Auto" HorizontalScrollMode="Disabled">
        <Grid Margin="32" RowSpacing="20" MaxWidth="800" HorizontalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Spacing="4">
                <TextBlock FontSize="28" FontWeight="SemiBold" Text="Settings" />
                <TextBlock FontSize="13" Foreground="{StaticResource TextSecondary}"
                           Text="Personalize how the app behaves after login." />
            </StackPanel>

            <!-- Display section -->
            <Border Grid.Row="1" CornerRadius="12" Padding="20"
                    Background="{StaticResource CardBackground}"
                    BorderBrush="{StaticResource DividerBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Display" />

                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock FontWeight="Medium" Text="Items per page" />
                            <TextBlock FontSize="12" Foreground="{StaticResource TextSecondary}"
                                       Text="Used in Products, Orders and other lists." />
                        </StackPanel>
                        <ComboBox Grid.Column="1" MinWidth="100"
                                  ItemsSource="{Binding PageSizeOptions}"
                                  SelectedItem="{Binding PageSize, Mode=TwoWay}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Navigation section -->
            <Border Grid.Row="2" CornerRadius="12" Padding="20"
                    Background="{StaticResource CardBackground}"
                    BorderBrush="{StaticResource DividerBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Navigation" />

                    <ToggleSwitch Header="Open last screen on startup"
                                  IsOn="{Binding RememberLastScreen, Mode=TwoWay}" />
                    <TextBlock FontSize="12" Foreground="{StaticResource TextSecondary}"
                               Text="When enabled, the app jumps to the screen you last used after you log in." />
                </StackPanel>
            </Border>

            <!-- Status -->
            <InfoBar Grid.Row="3"
                     IsOpen="{Binding StatusMessage, Converter={StaticResource StringToBooleanConverter}}"
                     IsClosable="False"
                     Severity="Success"
                     Message="{Binding StatusMessage}" />

            <!-- Save -->
            <Button Grid.Row="4"
                    HorizontalAlignment="Right"
                    Command="{Binding SaveCommand}"
                    Content="Save changes"
                    Style="{StaticResource AccentButtonStyle}" />
        </Grid>
    </ScrollViewer>
</Page>
