<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="hcmus_shop.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  Left Panel â€” Branding  -->
        <Grid Grid.Column="0" Background="{StaticResource LoginPrimaryBrush}">
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12">
                <FontIcon
                    HorizontalAlignment="Center"
                    FontFamily="{StaticResource SymbolThemeFontFamily}"
                    Foreground="{StaticResource LoginCardBackgroundBrush}"
                    Glyph="&#xE719;"
                    Style="{StaticResource BrandBigIconStyle}" />
                <TextBlock
                    HorizontalAlignment="Center"
                    Foreground="{StaticResource LoginCardBackgroundBrush}"
                    Style="{StaticResource CardTitleStyle}"
                    Text="MyShop" />
                <TextBlock
                    HorizontalAlignment="Center"
                    Foreground="{StaticResource LoginCardBackgroundBrush}"
                    Style="{StaticResource BodySecondaryTextStyle}"
                    Text="Laptop Store Management System" />
            </StackPanel>

            <!--  Version at bottom-left  -->
            <TextBlock
                Margin="20,0,0,16"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Foreground="{StaticResource LoginCardBackgroundBrush}"
                Style="{StaticResource BodySecondaryTextStyle}"
                Text="{x:Bind VersionText}" />
        </Grid>

        <!--  Right Panel â€” Login Form  -->
        <Grid Grid.Column="1" Background="{StaticResource LoginRightPanelBrush}">

            <!--  Config button top-right  -->
            <Button
                Margin="0,16,16,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Command="{Binding OpenConfigCommand}"
                Style="{StaticResource GhostButtonStyle}"
                ToolTipService.ToolTip="Server Configuration">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon
                        FontFamily="{StaticResource SymbolThemeFontFamily}"
                        Glyph="&#xE713;"
                        Style="{StaticResource SortGlyphIconStyle}" />
                </StackPanel>
            </Button>

            <!--  Login Card  -->
            <Border
                Width="380"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Style="{StaticResource LoginCardBorderStyle}">
                <StackPanel Spacing="4">

                    <!--  Header  -->
                    <TextBlock Style="{StaticResource CardTitleStyle}" Text="Welcome back" />
                    <TextBlock
                        Margin="0,2,0,20"
                        Style="{StaticResource BodySecondaryTextStyle}"
                        Text="Sign in to continue to your dashboard" />

                    <!--  Username  -->
                    <TextBlock
                        Margin="0,0,0,4"
                        Style="{StaticResource FieldLabelStyle}"
                        Text="Username" />
                    <TextBox
                        PlaceholderText="Enter your username"
                        Style="{StaticResource LoginTextBoxStyle}"
                        Text="{Binding Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <!--  Password  -->
                    <TextBlock
                        Margin="0,14,0,4"
                        Style="{StaticResource FieldLabelStyle}"
                        Text="Password" />
                    <PasswordBox
                        x:Name="PasswordInput"
                        PasswordChanged="PasswordInput_PasswordChanged"
                        PlaceholderText="Enter your password"
                        Style="{StaticResource LoginPasswordBoxStyle}" />

                    <!--  Remember me  -->
                    <CheckBox
                        Margin="-2,8,0,0"
                        Content="Remember me"
                        Foreground="{StaticResource TextPrimary}"
                        IsChecked="{Binding RememberMe, Mode=TwoWay}" />

                    <!--  Error message  -->
                    <InfoBar
                        Margin="0,4,0,0"
                        IsClosable="False"
                        IsOpen="{Binding HasError}"
                        Message="{Binding ErrorMessage}"
                        Severity="Error" />

                    <!--  Login button  -->
                    <Button
                        Margin="0,16,0,0"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Command="{Binding LoginCommand}"
                        Content="Sign In"
                        Style="{StaticResource AccentButtonStyle}" />

                    <!--  Server status  -->
                    <TextBlock
                        Margin="0,16,0,0"
                        HorizontalAlignment="Center"
                        Style="{StaticResource CaptionSecondaryTextStyle}"
                        Text="{x:Bind ServerUrlText}" />

                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>



