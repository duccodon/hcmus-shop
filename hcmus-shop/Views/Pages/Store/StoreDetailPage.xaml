<Page
    x:Class="hcmus_shop.Views.StoreDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:hcmus_shop.ViewModels.Store"
    x:Name="Root">

    <Grid Background="{StaticResource DashboardBackground}">
        <ScrollViewer>
            <Grid Margin="24">
                <Border Style="{StaticResource ContentCardBorderStyle}">
                    <Grid RowSpacing="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button
                                Style="{StaticResource GhostButtonStyle}"
                                Click="BackButton_Click">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE72B;" />
                                    <TextBlock Text="Back to catalog" />
                                </StackPanel>
                            </Button>
                            <StackPanel Grid.Column="1" Margin="16,0,0,0" Spacing="4">
                                <TextBlock Text="Product Detail" Style="{StaticResource PageTitleStyle}" />
                                <TextBlock Text="Full customer-safe information, image gallery, and key technical highlights." Style="{StaticResource BodySecondaryTextStyle}" />
                            </StackPanel>
                        </Grid>

                        <InfoBar
                            Grid.Row="1"
                            IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                            IsClosable="False"
                            Severity="Error"
                            Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" />

                        <Grid Grid.Row="2" ColumnSpacing="18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.15*" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Spacing="14">
                                <Border
                                    Width="520"
                                    Height="360"
                                    Style="{StaticResource FormCardBorderStyle}">
                                    <Grid>
                                        <Image
                                            Stretch="UniformToFill"
                                            Visibility="{x:Bind ViewModel.HasSelectedImage, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <Image.Source>
                                                <BitmapImage UriSource="{x:Bind ViewModel.SelectedImageUri, Mode=OneWay}" />
                                            </Image.Source>
                                        </Image>
                                        <FontIcon
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontFamily="Segoe Fluent Icons"
                                            Glyph="&#xE7F8;"
                                            FontSize="42"
                                            Foreground="{StaticResource TextSecondary}"
                                            Visibility="{x:Bind ViewModel.HasSelectedImage, Mode=OneWay, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                    </Grid>
                                </Border>

                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                    <ItemsControl ItemsSource="{x:Bind ViewModel.Images, Mode=OneWay}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="10" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:StoreGalleryImageViewModel">
                                                <Button
                                                    Style="{StaticResource ImageUploadPreviewButtonStyle}"
                                                    Command="{Binding DataContext.ViewModel.SelectImageCommand, ElementName=Root}"
                                                    CommandParameter="{x:Bind}">
                                                    <Image Width="88" Height="88" Stretch="UniformToFill">
                                                        <Image.Source>
                                                            <BitmapImage UriSource="{x:Bind ImageUri, Mode=OneWay}" />
                                                        </Image.Source>
                                                    </Image>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>

                            <ScrollViewer Grid.Column="1">
                                <StackPanel Spacing="14">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="{x:Bind ViewModel.Name, Mode=OneWay}" Style="{StaticResource PageTitleStyle}" TextWrapping="WrapWholeWords" />
                                        <TextBlock Text="{x:Bind ViewModel.BrandName, Mode=OneWay}" Style="{StaticResource BodySecondaryTextStyle}" />
                                    </StackPanel>

                                    <ItemsControl ItemsSource="{x:Bind ViewModel.CategoryChips, Mode=OneWay}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapGrid Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border
                                                    Margin="0,0,8,8"
                                                    Padding="10,5"
                                                    Background="{StaticResource SelectionHighlight}"
                                                    CornerRadius="8">
                                                    <TextBlock Text="{Binding}" Style="{StaticResource BodySecondaryTextStyle}" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource FormCardBorderStyle}">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="Selling Price" Style="{StaticResource FieldLabelStyle}" />
                                                <TextBlock Text="{x:Bind ViewModel.PriceDisplay, Mode=OneWay}" Style="{StaticResource CardTitleStyle}" />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="1" Style="{StaticResource FormCardBorderStyle}">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="Available Stock" Style="{StaticResource FieldLabelStyle}" />
                                                <TextBlock Text="{x:Bind ViewModel.StockDisplay, Mode=OneWay}" Style="{StaticResource CardTitleStyle}" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="SKU" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBlock Text="{x:Bind ViewModel.Sku, Mode=OneWay}" Style="{StaticResource BodyTextStyle}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Spacing="4">
                                            <TextBlock Text="Series" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBlock Text="{x:Bind ViewModel.SeriesName, Mode=OneWay}" Style="{StaticResource BodyTextStyle}" />
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Highlights" Style="{StaticResource FieldLabelStyle}" />
                                        <ItemsControl ItemsSource="{x:Bind ViewModel.HighlightLines, Mode=OneWay}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Margin="0,0,0,6" Text="{Binding}" Style="{StaticResource BodyTextStyle}" TextWrapping="WrapWholeWords" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Description" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBlock Text="{x:Bind ViewModel.Description, Mode=OneWay}" Style="{StaticResource BodyTextStyle}" TextWrapping="WrapWholeWords" />
                                    </StackPanel>

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Warranty" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBlock Text="{x:Bind ViewModel.WarrantyDisplay, Mode=OneWay}" Style="{StaticResource BodyTextStyle}" />
                                    </StackPanel>

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Raw Specifications" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBlock Text="{x:Bind ViewModel.SpecificationsDisplay, Mode=OneWay}" Style="{StaticResource BodySecondaryTextStyle}" TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
