<Page
    x:Class="hcmus_shop.Views.StorePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="using:hcmus_shop.Views.Components.Pagination"
    xmlns:vm="using:hcmus_shop.ViewModels.Store"
    x:Name="Root">

    <Grid Background="{StaticResource DashboardBackground}">
        <ScrollViewer>
            <Grid Margin="24" ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <Border Background="{StaticResource CardBackground}" CornerRadius="16" Padding="20">
                    <Grid RowSpacing="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Laptop Catalog" Style="{StaticResource PageTitleStyle}" />
                            <TextBlock Text="Sales can browse ready-to-sell laptops here, review customer-safe specs, and use the information during order creation." Style="{StaticResource BodySecondaryTextStyle}" TextWrapping="WrapWholeWords" />
                        </StackPanel>

                        <Border Grid.Row="1" Height="1" Background="{StaticResource DividerBrush}" />

                        <Border
                            Grid.Row="2"
                            Padding="14"
                            Background="{StaticResource SelectionHighlight}"
                            CornerRadius="12">
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox
                                    PlaceholderText="Search products..."
                                    Style="{StaticResource SearchTextBoxStyle}"
                                    Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <ComboBox
                                    Grid.Column="1"
                                    Style="{StaticResource FormComboBoxStyle}"
                                    ItemsSource="{x:Bind ViewModel.BrandOptions, Mode=OneWay}"
                                    SelectedItem="{x:Bind ViewModel.SelectedBrand, Mode=TwoWay}"
                                    DisplayMemberPath="Name" />
                                <ComboBox
                                    Grid.Column="2"
                                    Style="{StaticResource FormComboBoxStyle}"
                                    ItemsSource="{x:Bind ViewModel.CategoryOptions, Mode=OneWay}"
                                    SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}"
                                    DisplayMemberPath="Name" />
                                <ToggleSwitch
                                    Grid.Column="3"
                                    Header="Only show in stock"
                                    VerticalAlignment="Center"
                                    IsOn="{x:Bind ViewModel.InStockOnly, Mode=TwoWay}" />
                                <Button
                                    Grid.Column="4"
                                    Content="Refresh"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{x:Bind ViewModel.RefreshCommand}" />
                            </Grid>
                        </Border>

                        <Grid Grid.Row="3" MinHeight="420">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <InfoBar
                                Grid.RowSpan="2"
                                Margin="0,0,0,12"
                                IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                                IsClosable="False"
                                Severity="Error"
                                Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" />

                            <ListView
                                Grid.Row="1"
                                ItemsSource="{x:Bind ViewModel.Products, Mode=OneWay}"
                                SelectedItem="{x:Bind ViewModel.SelectedProductCard, Mode=TwoWay}">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:StoreProductListItemViewModel">
                                        <Border Background="{StaticResource SelectionHighlight}" CornerRadius="14" Padding="12" Margin="0,0,0,10">
                                            <Grid ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="84" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Width="84" Height="84" CornerRadius="12" Background="{StaticResource CardBackground}">
                                                    <Grid>
                                                        <Image Stretch="UniformToFill" Visibility="{x:Bind HasThumbnail, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                            <Image.Source>
                                                                <BitmapImage UriSource="{x:Bind ThumbnailUri, Mode=OneWay}" />
                                                            </Image.Source>
                                                        </Image>
                                                        <FontIcon
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            FontFamily="Segoe Fluent Icons"
                                                            Glyph="&#xE7F8;"
                                                            FontSize="24"
                                                            Foreground="{StaticResource TextSecondary}"
                                                            Visibility="{x:Bind HasThumbnail, Mode=OneWay, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                                    </Grid>
                                                </Border>
                                                <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                                    <TextBlock Text="{x:Bind Name}" Style="{StaticResource BodyTextStyle}" TextWrapping="WrapWholeWords" />
                                                    <TextBlock Text="{x:Bind BrandName}" Style="{StaticResource BodySecondaryTextStyle}" />
                                                    <TextBlock Text="{x:Bind PriceDisplay}" Style="{StaticResource CardTitleStyle}" />
                                                    <TextBlock Text="{x:Bind StockDisplay}" Style="{StaticResource BodySecondaryTextStyle}" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <Border
                                Grid.Row="1"
                                Background="Transparent"
                                Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource EmptyStateTextStyle}"
                                    Text="No laptops match the current catalog filters." />
                            </Border>
                        </Grid>

                        <components:PaginationFooter
                            Grid.Row="4"
                            ResultText="{x:Bind ViewModel.ResultText, Mode=OneWay}"
                            PageSizeOptions="{x:Bind ViewModel.PageSizeOptions, Mode=OneWay}"
                            SelectedPageSize="{x:Bind ViewModel.SelectedPageSize, Mode=TwoWay}"
                            PageButtons="{x:Bind ViewModel.PageButtons, Mode=OneWay}"
                            PageButtonClickCommand="{x:Bind ViewModel.GoToPageCommand}" />
                    </Grid>
                </Border>

                <Border Grid.Column="1" Background="{StaticResource CardBackground}" CornerRadius="16" Padding="20">
                    <Grid>
                        <ScrollViewer Visibility="{x:Bind ViewModel.HasSelectedProduct, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Spacing="14">
                                <Border Height="240" CornerRadius="16" Background="{StaticResource SelectionHighlight}">
                                    <Grid>
                                        <Image Stretch="UniformToFill" Visibility="{x:Bind ViewModel.SelectedProductHasPrimaryImage, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <Image.Source>
                                                <BitmapImage UriSource="{x:Bind ViewModel.SelectedProductPrimaryImageUri, Mode=OneWay}" />
                                            </Image.Source>
                                        </Image>
                                        <FontIcon
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontFamily="Segoe Fluent Icons"
                                            Glyph="&#xE7F8;"
                                            FontSize="36"
                                            Foreground="{StaticResource TextSecondary}"
                                            Visibility="{x:Bind ViewModel.SelectedProductHasPrimaryImage, Mode=OneWay, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                    </Grid>
                                </Border>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Bind ViewModel.SelectedProductName, Mode=OneWay}" Style="{StaticResource PageTitleStyle}" TextWrapping="WrapWholeWords" />
                                    <TextBlock Text="{x:Bind ViewModel.SelectedProductBrandName, Mode=OneWay}" Style="{StaticResource BodySecondaryTextStyle}" />
                                </StackPanel>

                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Background="{StaticResource SelectionHighlight}" CornerRadius="12" Padding="12">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Selling Price" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBlock Text="{x:Bind ViewModel.SelectedProductSellingPriceDisplay, Mode=OneWay}" Style="{StaticResource CardTitleStyle}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Background="{StaticResource SelectionHighlight}" CornerRadius="12" Padding="12">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Available Serials" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBlock Text="{x:Bind ViewModel.SelectedProductAvailableSerialCount, Mode=OneWay}" Style="{StaticResource CardTitleStyle}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="SKU" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBlock Text="{x:Bind ViewModel.SelectedProductSku, Mode=OneWay}" Style="{StaticResource BodyTextStyle}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="4">
                                        <TextBlock Text="Series" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBlock Text="{x:Bind ViewModel.SelectedProductSeriesName, Mode=OneWay}" Style="{StaticResource BodyTextStyle}" />
                                    </StackPanel>
                                </Grid>

                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Categories" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBlock Text="{x:Bind ViewModel.SelectedProductCategoriesDisplay, Mode=OneWay}" Style="{StaticResource BodyTextStyle}" TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="4">
                                        <TextBlock Text="Warranty" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBlock Text="{x:Bind ViewModel.SelectedProductWarrantyDisplay, Mode=OneWay}" Style="{StaticResource BodyTextStyle}" />
                                    </StackPanel>
                                </Grid>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="Stock" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBlock Text="{x:Bind ViewModel.SelectedProductStockDisplay, Mode=OneWay}" Style="{StaticResource BodyTextStyle}" />
                                </StackPanel>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="Description" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBlock Text="{x:Bind ViewModel.SelectedProductDescription, Mode=OneWay}" Style="{StaticResource BodyTextStyle}" TextWrapping="WrapWholeWords" />
                                </StackPanel>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="Specifications" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBlock Text="{x:Bind ViewModel.SelectedProductSpecificationsDisplay, Mode=OneWay}" Style="{StaticResource BodySecondaryTextStyle}" TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>

                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Text="Select a laptop from the catalog to see its full sale-ready details."
                            Style="{StaticResource EmptyStateTextStyle}"
                            TextWrapping="WrapWholeWords"
                            Visibility="{x:Bind ViewModel.HasSelectedProduct, Mode=OneWay, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
