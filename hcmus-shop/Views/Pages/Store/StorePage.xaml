<Page
    x:Class="hcmus_shop.Views.StorePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="using:hcmus_shop.Views.Components.Pagination"
    xmlns:vm="using:hcmus_shop.ViewModels.Store"
    x:Name="Root">

    <Grid Background="{StaticResource DashboardBackground}">
        <ScrollViewer>
            <Grid Margin="24">
                <Border Style="{StaticResource ContentCardBorderStyle}">
                    <Grid RowSpacing="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Laptop Catalog" Style="{StaticResource PageTitleStyle}" />
                                <TextBlock Text="Browse sale-ready laptops, compare customer-safe specifications, and open the full detail page for every gallery image." Style="{StaticResource BodySecondaryTextStyle}" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <Button
                                Grid.Column="1"
                                Content="Refresh"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{x:Bind ViewModel.RefreshCommand}" />
                        </Grid>

                        <Border Grid.Row="1" Height="1" Background="{StaticResource DividerBrush}" />

                        <Border Grid.Row="2" Background="{StaticResource SelectionHighlight}" CornerRadius="12" Padding="14">
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="170" />
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox
                                    PlaceholderText="Search products..."
                                    Style="{StaticResource SearchTextBoxStyle}"
                                    Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <ComboBox
                                    Grid.Column="1"
                                    Style="{StaticResource FormComboBoxStyle}"
                                    ItemsSource="{x:Bind ViewModel.BrandOptions, Mode=OneWay}"
                                    SelectedItem="{x:Bind ViewModel.SelectedBrand, Mode=TwoWay}"
                                    DisplayMemberPath="Name" />
                                <ComboBox
                                    Grid.Column="2"
                                    Style="{StaticResource FormComboBoxStyle}"
                                    ItemsSource="{x:Bind ViewModel.CategoryOptions, Mode=OneWay}"
                                    SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}"
                                    DisplayMemberPath="Name" />
                                <ComboBox
                                    Grid.Column="3"
                                    Style="{StaticResource FormComboBoxStyle}"
                                    ItemsSource="{x:Bind ViewModel.SortFieldOptions, Mode=OneWay}"
                                    SelectedItem="{x:Bind ViewModel.SelectedSortField, Mode=TwoWay}"
                                    DisplayMemberPath="Label" />
                                <ComboBox
                                    Grid.Column="4"
                                    Style="{StaticResource FormComboBoxStyle}"
                                    ItemsSource="{x:Bind ViewModel.SortDirectionOptions, Mode=OneWay}"
                                    SelectedItem="{x:Bind ViewModel.SelectedSortDirection, Mode=TwoWay}"
                                    DisplayMemberPath="Label" />
                                <ToggleSwitch
                                    Grid.Column="5"
                                    Header="In stock only"
                                    IsOn="{x:Bind ViewModel.InStockOnly, Mode=TwoWay}"
                                    VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <Grid Grid.Row="3" MinHeight="520">
                            <InfoBar
                                Margin="0,0,0,12"
                                IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                                IsClosable="False"
                                Severity="Error"
                                Visibility="{x:Bind ViewModel.HasError, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                                Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" />

                            <ItemsControl ItemsSource="{x:Bind ViewModel.Products, Mode=OneWay}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapGrid Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:StoreProductCardViewModel">
                                        <Button
                                            Margin="0,0,16,16"
                                            Width="280"
                                            Padding="0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Command="{Binding DataContext.ViewModel.OpenProductCommand, ElementName=Root}"
                                            CommandParameter="{x:Bind}">
                                            <Border Style="{StaticResource FormCardBorderStyle}" MinHeight="420">
                                                <Grid RowSpacing="12">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="200" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="*" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <Border
                                                        Padding="10,5"
                                                        HorizontalAlignment="Left"
                                                        Background="{StaticResource SelectionHighlight}"
                                                        CornerRadius="8">
                                                        <TextBlock Text="{x:Bind BadgeText}" Style="{StaticResource StatusBadgeTextStyle}" Foreground="{StaticResource TextPrimary}" />
                                                    </Border>

                                                    <Border
                                                        Grid.Row="1"
                                                        Style="{StaticResource ImageUploadSurfaceStyle}">
                                                        <Grid>
                                                            <Image
                                                                Stretch="UniformToFill"
                                                                Visibility="{x:Bind HasThumbnail, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                <Image.Source>
                                                                    <BitmapImage UriSource="{x:Bind ThumbnailUri, Mode=OneWay}" />
                                                                </Image.Source>
                                                            </Image>
                                                            <FontIcon
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                FontFamily="Segoe Fluent Icons"
                                                                Glyph="&#xE7F8;"
                                                                FontSize="28"
                                                                Foreground="{StaticResource TextSecondary}"
                                                                Visibility="{x:Bind HasThumbnail, Mode=OneWay, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                                        </Grid>
                                                    </Border>

                                                    <StackPanel Grid.Row="2" Spacing="6">
                                                        <TextBlock Text="{x:Bind Name}" Style="{StaticResource CardTitleStyle}" TextWrapping="WrapWholeWords" />
                                                        <TextBlock Text="{x:Bind BrandName}" Style="{StaticResource BodySecondaryTextStyle}" />
                                                    </StackPanel>

                                                    <ItemsControl Grid.Row="3" ItemsSource="{x:Bind Highlights, Mode=OneWay}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Margin="0,0,0,6" Text="{Binding}" Style="{StaticResource BodyTextStyle}" TextWrapping="WrapWholeWords" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                    <StackPanel Grid.Row="4" Spacing="6">
                                                        <TextBlock Text="{x:Bind PriceDisplay}" Style="{StaticResource PageTitleStyle}" />
                                                        <TextBlock Text="{x:Bind AvailabilityText}" Style="{StaticResource BodySecondaryTextStyle}" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border
                                Background="Transparent"
                                Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource EmptyStateTextStyle}"
                                    Text="No laptops match the current catalog filters." />
                            </Border>
                        </Grid>

                        <components:PaginationFooter
                            Grid.Row="4"
                            ResultText="{x:Bind ViewModel.ResultText, Mode=OneWay}"
                            PageSizeOptions="{x:Bind ViewModel.PageSizeOptions, Mode=OneWay}"
                            SelectedPageSize="{x:Bind ViewModel.SelectedPageSize, Mode=TwoWay}"
                            PageButtons="{x:Bind ViewModel.PageButtons, Mode=OneWay}"
                            PageButtonClickCommand="{x:Bind ViewModel.GoToPageCommand}" />
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
