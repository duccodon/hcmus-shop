<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="hcmus_shop.Views.Components.BulkActionBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="Root">

    <Border
        Padding="12,8"
        Background="{StaticResource SelectionHighlight}"
        CornerRadius="8"
        Visibility="{x:Bind IsVisible, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                VerticalAlignment="Center"
                Style="{StaticResource BodySecondaryTextStyle}"
                Text="{x:Bind SelectionText, Mode=OneWay}" />
            <StackPanel
                Grid.Column="1"
                Orientation="Horizontal"
                Spacing="8">
                <Button
                    Command="{x:Bind ToggleStatusCommand, Mode=OneWay}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    ToolTipService.ToolTip="Toggle active / inactive">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE70F;" />
                        <TextBlock
                            VerticalAlignment="Center"
                            Style="{StaticResource BodySecondaryTextStyle}"
                            Text="Update Status" />
                    </StackPanel>
                </Button>
                <Button
                    Command="{x:Bind DeleteCommand, Mode=OneWay}"
                    Style="{StaticResource DangerButtonStyle}"
                    ToolTipService.ToolTip="Delete selected">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon
                            FontFamily="Segoe Fluent Icons"
                            Foreground="{StaticResource DangerForeground}"
                            Glyph="&#xE74D;" />
                        <TextBlock
                            VerticalAlignment="Center"
                            Foreground="{StaticResource DangerForeground}"
                            Style="{StaticResource BodySecondaryTextStyle}"
                            Text="Delete" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>

