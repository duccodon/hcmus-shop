<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="hcmus_shop.Views.Components.PageHeader"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="Root">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock
            VerticalAlignment="Center"
            Style="{StaticResource PageTitleStyle}"
            Text="{x:Bind Title, Mode=OneWay}" />

        <StackPanel
            Grid.Column="1"
            Orientation="Horizontal"
            Spacing="8">
            <Button
                Command="{x:Bind ImportCommand, Mode=OneWay}"
                Content="Import"
                Style="{StaticResource PrimaryButtonStyle}" />
            <Button
                Command="{x:Bind ExportCommand, Mode=OneWay}"
                Content="Export"
                Style="{StaticResource PrimaryButtonStyle}" />
            <Button
                Command="{x:Bind PrimaryActionCommand, Mode=OneWay}"
                Content="{x:Bind PrimaryActionLabel, Mode=OneWay}"
                Style="{StaticResource PrimaryButtonStyle}" />
        </StackPanel>
    </Grid>
</UserControl>
