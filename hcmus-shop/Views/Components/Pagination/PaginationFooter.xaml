<UserControl
    x:Class="hcmus_shop.Views.Components.Pagination.PaginationFooter"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="Root">

    <Grid Margin="0,6,0,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel
            VerticalAlignment="Center"
            Orientation="Horizontal"
            Spacing="8">
            <TextBlock
                VerticalAlignment="Center"
                Foreground="{StaticResource TextSecondary}"
                Style="{StaticResource BodyTextStyle}"
                Text="{x:Bind ResultText, Mode=OneWay}" />
            <ComboBox
                Width="75"
                ItemsSource="{x:Bind PageSizeOptions, Mode=OneWay}"
                SelectedItem="{x:Bind SelectedPageSize, Mode=TwoWay}" />
        </StackPanel>
        <TextBlock
            Grid.Column="1"
            VerticalAlignment="Center"
            Foreground="{StaticResource TextSecondary}"
            Text="{x:Bind CenterText, Mode=OneWay}" />
        <ItemsControl Grid.Column="2" ItemsSource="{x:Bind PageButtons, Mode=OneWay}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="6" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button
                        Background="{Binding IsCurrent, Converter={StaticResource PageButtonBackgroundConverter}}"
                        Command="{Binding PageButtonClickCommand, ElementName=Root}"
                        CommandParameter="{Binding PageNumber}"
                        Content="{Binding Label}"
                        Foreground="{Binding IsCurrent, Converter={StaticResource PageButtonForegroundConverter}}"
                        IsEnabled="{Binding IsEnabled}"
                        Style="{StaticResource PaginationButtonStyle}" />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
