<UserControl
    x:Class="hcmus_shop.Views.Dashboard.Components.Charts.SalesAnalyticsCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    x:Name="Root">

    <Border
        Background="{StaticResource CardBackground}"
        CornerRadius="16"
        Padding="16">
        <StackPanel Spacing="12">
            <TextBlock Text="Sales Analytics" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" FontSize="18" />
            <lvc:CartesianChart
                Height="250"
                Series="{x:Bind Root.Series, Mode=OneWay}"
                XAxes="{x:Bind Root.XAxes, Mode=OneWay}"
                YAxes="{x:Bind Root.YAxes, Mode=OneWay}"
                LegendPosition="Hidden" />
        </StackPanel>
    </Border>
</UserControl>
