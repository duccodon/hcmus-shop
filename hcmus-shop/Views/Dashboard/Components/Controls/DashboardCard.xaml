<UserControl
    x:Class="hcmus_shop.Views.Dashboard.Components.Controls.DashboardCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:hcmus_shop.Views.Dashboard.Components.Controls">

    <Border
        Background="{StaticResource CardBackground}"
        CornerRadius="16"
        Padding="16">
        <StackPanel Spacing="10">
            <StackPanel>
                <TextBlock
                    FontSize="18"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextPrimary}"
                    Text="{x:Bind Title, Mode=OneWay}" />
                <TextBlock
                    FontSize="12"
                    Foreground="{StaticResource TextSecondary}"
                    Text="{x:Bind Subtitle, Mode=OneWay}" />
            </StackPanel>

            <ContentPresenter Content="{x:Bind CardContent, Mode=OneWay}" />
        </StackPanel>
    </Border>
</UserControl>