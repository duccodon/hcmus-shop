<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="hcmus_shop.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:hcmus_shop"
    xmlns:views="using:hcmus_shop.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="hcmus-shop">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
            <NavigationView x:Name="AppNavigationView" SelectionChanged="AppNavigationView_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem x:Name="DashboardItem" Content="Dashboard" Icon="Home" Tag="Dashboard" />
                <NavigationViewItem x:Name="StoreItem" Content="Store" Icon="Shop" Tag="Store" />
                <NavigationViewItem x:Name="OrdersItem" Content="Orders" Icon="Shop" Tag="Orders" />
                <NavigationViewItem x:Name="ProductsItem" Content="Products" Icon="AllApps" Tag="Products" />
                <NavigationViewItem x:Name="PromotionsItem" Content="Promotions" Icon="Tag" Tag="Promotions" />
                <NavigationViewItem x:Name="CustomersItem" Content="Customers" Icon="Contact" Tag="Customers" />
                <NavigationViewItem x:Name="ReportsItem" Content="Reports" Tag="Reports">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="View" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="AdminItem" Content="Admin" Icon="Admin" Tag="Admin" />
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem x:Name="SettingsItem" Content="Settings" Icon="Setting" Tag="Settings" />
                <NavigationViewItem x:Name="LogoutItem" Content="Log Out" Tag="Logout">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xF3B1;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <Frame x:Name="ContentFrame" />
        </NavigationView>

        <!-- Onboarding TeachingTips. Shown once per machine on first login. -->
        <TeachingTip x:Name="WelcomeTip"
                     Title="Welcome to HCMUS Shop!"
                     Subtitle="A quick tour to get you started. You can skip any time."
                     PreferredPlacement="Center"
                     ActionButtonContent="Next"
                     ActionButtonClick="OnTipNext"
                     CloseButtonContent="Skip"
                     CloseButtonClick="OnTipSkip" />

        <TeachingTip x:Name="DashboardTip"
                     Title="Dashboard"
                     Subtitle="Get an overview of your shop — sales today, low-stock items, recent orders."
                     ActionButtonContent="Next"
                     ActionButtonClick="OnTipNext"
                     CloseButtonContent="Skip"
                     CloseButtonClick="OnTipSkip" />

        <TeachingTip x:Name="ProductsTip"
                     Title="Catalog"
                     Subtitle="Browse products, check laptop details, and access catalog tools here."
                     ActionButtonContent="Next"
                     ActionButtonClick="OnTipNext"
                     CloseButtonContent="Skip"
                     CloseButtonClick="OnTipSkip" />

        <TeachingTip x:Name="SettingsTip"
                     Title="Settings"
                     Subtitle="Adjust page size, restore the last screen, and back up your data."
                     ActionButtonContent="Done"
                     ActionButtonClick="OnTipFinish"
                     CloseButtonContent="Skip"
                     CloseButtonClick="OnTipSkip" />
    </Grid>
</Window>
